{
  "name": "yulaa",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/marketing",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "dev:web": "turbo run dev --filter=@yulaa/web",
    "dev:marketing": "turbo run dev --filter=@yulaa/marketing",
    "dev:mobile": "turbo run dev --filter=@yulaa/mobile",
    "build:web": "turbo run build --filter=@yulaa/web"
  },
  "dependencies": {
    "ioredis": "^5.10.0"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2"
}