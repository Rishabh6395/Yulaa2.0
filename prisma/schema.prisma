generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id                    String                 @id @default(uuid())
  name                  String                 @db.VarChar(200)
  address               String?
  email                 String?                @unique @db.VarChar(100)
  phone                 String?                @db.VarChar(20)
  logoUrl               String?                @map("logo_url")
  status                String                 @default("active") @db.VarChar(20)
  subscriptionPlan      String                 @default("basic") @map("subscription_plan") @db.VarChar(20)
  createdAt             DateTime               @default(now()) @map("created_at")
  admissionFeeAmt       Decimal?               @map("admission_fee_amt") @db.Decimal(10, 2)
  admissionsOpen        Boolean                @default(false) @map("admissions_open")
  city                  String?                @db.VarChar(100)
  description           String?
  facilities            String[]
  state                 String?                @db.VarChar(100)
  website               String?                @db.VarChar(200)
  boardType             String?                @map("board_type") @db.VarChar(30)
  isDefault             Boolean                @default(false) @map("is_default")
  latitude              Float?
  longitude             Float?
  admissionApplications AdmissionApplication[]
  admissionWorkflows    AdmissionWorkflow[]
  announcements         Announcement[]
  attendance            Attendance[]
  classes               Class[]
  complianceItems       ComplianceItem[]
  consultantContracts   ConsultantContract[]
  consultantSessions    ConsultantSession[]
  feeInvoices           FeeInvoice[]
  feeStructures         FeeStructure[]
  holidayCalendar       HolidayCalendar[]
  homework              Homework[]
  leaveBalancePolicies  LeaveBalancePolicy[]
  leaveRequests         LeaveRequest[]
  leaveTypeMasters      LeaveTypeMaster[]
  leaveWorkflows        LeaveWorkflow[]
  queries               StudentQuery[]
  supportQueries        SupportQuery[]
  students              Student[]
  teacherLeaveBalances  TeacherLeaveBalance[]
  teachers              Teacher[]
  menuPermissions       MenuPermission[]
  timetables            Timetable[]
  transportRoutes       TransportRoute[]
  userRoles             UserRole[]
  vendorInventory       VendorInventory[]

  @@map("schools")
}

model Role {
  id          String     @id @default(uuid())
  code        String     @unique @db.VarChar(30)
  displayName String     @map("display_name") @db.VarChar(100)
  description String?
  userRoles   UserRole[]

  @@map("roles")
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique @db.VarChar(100)
  passwordHash          String                 @map("password_hash")
  firstName             String                 @map("first_name") @db.VarChar(100)
  lastName              String                 @map("last_name") @db.VarChar(100)
  phone                 String?                @db.VarChar(20)
  avatarUrl             String?                @map("avatar_url")
  status                String                 @default("active") @db.VarChar(20)
  createdAt             DateTime               @default(now()) @map("created_at")
  mustResetPassword     Boolean                @default(false) @map("must_reset_password")
  admissionActions      AdmissionAction[]      @relation("AdmissionActionActor")
  admissionApplications AdmissionApplication[] @relation("ApplicationParentUser")
  announcements         Announcement[]         @relation("CreatedBy")
  markedAttendance      Attendance[]           @relation("MarkedBy")
  updatedAttendance     Attendance[]           @relation("UpdatedBy")
  consultants           Consultant?
  leaveActions          LeaveAction[]          @relation("LeaveActionActor")
  reviewedLeaves        LeaveRequest[]         @relation("ReviewedBy")
  leaveRequests         LeaveRequest[]
  parents               Parent?
  respondedQueries      StudentQuery[]         @relation("RespondedBy")
  raisedSupportQueries  SupportQuery[]         @relation("SupportQueryRaisedBy")
  supportQueryReplies   SupportQueryReply[]    @relation("SupportQueryReplyUser")
  teachers              Teacher[]
  userRoles             UserRole[]
  vendors               Vendor?

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  schoolId  String?  @map("school_id")
  isPrimary Boolean  @default(true) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  school    School?  @relation(fields: [schoolId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleId])
  @@index([schoolId])
  @@map("user_roles")
}

model Teacher {
  id              String                @id @default(uuid())
  userId          String                @map("user_id")
  schoolId        String                @map("school_id")
  employeeId      String?               @map("employee_id") @db.VarChar(30)
  designation     String?               @db.VarChar(100)
  department      String?               @db.VarChar(100)
  qualification   String?
  experienceYears Int?                  @map("experience_years")
  joiningDate     DateTime?             @map("joining_date") @db.Date
  status          String                @default("active") @db.VarChar(20)
  createdAt       DateTime              @default(now()) @map("created_at")
  attendance      Attendance[]
  classes         Class[]
  homework        Homework[]
  leaveBalances   TeacherLeaveBalance[]
  school          School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  timetableSlots  TimetableSlot[]

  @@unique([userId, schoolId])
  @@index([schoolId])
  @@index([status])
  @@map("teachers")
}

model Student {
  id                  String               @id @default(uuid())
  userId              String?              @map("user_id")
  schoolId            String               @map("school_id")
  classId             String?              @map("class_id")
  admissionNo         String               @map("admission_no") @db.VarChar(30)
  firstName           String               @map("first_name") @db.VarChar(100)
  lastName            String               @map("last_name") @db.VarChar(100)
  dateOfBirth         DateTime?            @map("date_of_birth") @db.Date
  gender              String?              @db.VarChar(10)
  photoUrl            String?              @map("photo_url")
  address             String?
  bloodGroup          String?              @map("blood_group") @db.VarChar(5)
  emergencyContact    String?              @map("emergency_contact") @db.VarChar(200)
  status              String               @default("active") @db.VarChar(20)
  createdAt           DateTime             @default(now()) @map("created_at")
  aadhaarNo           String?              @map("aadhaar_no") @db.VarChar(12)
  admissionChildLink  AdmissionChild?      @relation("CreatedFromAdmission")
  attendance          Attendance[]
  feeInvoices         FeeInvoice[]
  homeworkSubmissions HomeworkSubmission[]
  leaveRequests       LeaveRequest[]
  parentStudents      ParentStudent[]
  queries             StudentQuery[]
  class               Class?               @relation(fields: [classId], references: [id])
  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([classId])
  @@index([status])
  @@map("students")
}

model Parent {
  id             String          @id @default(uuid())
  userId         String          @unique @map("user_id")
  occupation     String?
  createdAt      DateTime        @default(now()) @map("created_at")
  parentStudents ParentStudent[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  queries        StudentQuery[]

  @@map("parents")
}

model ParentStudent {
  id           String   @id @default(uuid())
  parentId     String   @map("parent_id")
  studentId    String   @map("student_id")
  relationship String?  @db.VarChar(30)
  isPrimary    Boolean  @default(true) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  parent       Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model Class {
  id             String         @id @default(uuid())
  schoolId       String         @map("school_id")
  name           String         @db.VarChar(50)
  grade          String         @db.VarChar(20)
  section        String         @db.VarChar(10)
  classTeacherId String?        @map("class_teacher_id")
  academicYear   String         @default("2025-2026") @map("academic_year") @db.VarChar(9)
  maxStudents    Int            @default(40) @map("max_students")
  createdAt      DateTime       @default(now()) @map("created_at")
  attendance     Attendance[]
  classTeacher   Teacher?       @relation(fields: [classTeacherId], references: [id])
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeStructures  FeeStructure[]
  homework       Homework[]
  students       Student[]
  timetables     Timetable[]

  @@unique([schoolId, grade, section, academicYear])
  @@map("classes")
}

model Attendance {
  id            String   @id @default(uuid())
  schoolId      String   @map("school_id")
  studentId     String?  @map("student_id")
  teacherId     String?  @map("teacher_id")
  classId       String?  @map("class_id")
  date          DateTime @db.Date
  status        String   @db.VarChar(10)
  markedBy      String?  @map("marked_by")
  remarks       String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  updatedBy     String?  @map("updated_by")
  class         Class?   @relation(fields: [classId], references: [id], onDelete: Cascade)
  markedByUser  User?    @relation("MarkedBy", fields: [markedBy], references: [id])
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher       Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  updatedByUser User?    @relation("UpdatedBy", fields: [updatedBy], references: [id])

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@index([classId])
  @@index([teacherId])
  @@map("attendance")
}

model FeeStructure {
  id           String       @id @default(uuid())
  schoolId     String       @map("school_id")
  classId      String?      @map("class_id")
  name         String       @db.VarChar(100)
  amount       Decimal      @db.Decimal(10, 2)
  frequency    String       @default("monthly") @db.VarChar(20)
  academicYear String       @default("2025-2026") @map("academic_year") @db.VarChar(9)
  createdAt    DateTime     @default(now()) @map("created_at")
  invoices     FeeInvoice[]
  class        Class?       @relation(fields: [classId], references: [id])
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("fee_structures")
}

model FeeInvoice {
  id             String        @id @default(uuid())
  schoolId       String        @map("school_id")
  studentId      String        @map("student_id")
  feeStructureId String?       @map("fee_structure_id")
  invoiceNo      String        @map("invoice_no") @db.VarChar(50)
  amount         Decimal       @db.Decimal(10, 2)
  dueDate        DateTime      @map("due_date") @db.Date
  status         String        @default("unpaid") @db.VarChar(20)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  paidAt         DateTime?     @map("paid_at")
  installmentNo  Int           @default(1) @map("installment_no")
  createdAt      DateTime      @default(now()) @map("created_at")
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments       FeePayment[]

  @@unique([schoolId, invoiceNo])
  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@map("fee_invoices")
}

model FeePayment {
  id             String     @id @default(uuid())
  invoiceId      String     @map("invoice_id")
  amount         Decimal    @db.Decimal(10, 2)
  paymentMethod  String     @default("online") @map("payment_method") @db.VarChar(30)
  transactionRef String?    @map("transaction_ref") @db.VarChar(100)
  paymentGateway String     @default("razorpay") @map("payment_gateway") @db.VarChar(30)
  status         String     @default("success") @db.VarChar(20)
  paidAt         DateTime   @default(now()) @map("paid_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  invoice        FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("fee_payments")
}

model Homework {
  id          String               @id @default(uuid())
  schoolId    String               @map("school_id")
  classId     String               @map("class_id")
  teacherId   String               @map("teacher_id")
  subject     String               @db.VarChar(100)
  title       String               @db.VarChar(200)
  description String?
  dueDate     DateTime             @map("due_date") @db.Date
  maxMarks    Int?                 @map("max_marks")
  createdAt   DateTime             @default(now()) @map("created_at")
  class       Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  school      School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher     Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  submissions HomeworkSubmission[]

  @@index([schoolId])
  @@index([classId])
  @@index([teacherId])
  @@index([dueDate])
  @@map("homework")
}

model HomeworkSubmission {
  id            String   @id @default(uuid())
  homeworkId    String   @map("homework_id")
  studentId     String   @map("student_id")
  submittedAt   DateTime @default(now()) @map("submitted_at")
  marksObtained Int?     @map("marks_obtained")
  feedback      String?
  status        String   @default("submitted") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")
  homework      Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@index([studentId])
  @@map("homework_submissions")
}

model Announcement {
  id            String    @id @default(uuid())
  schoolId      String    @map("school_id")
  title         String    @db.VarChar(200)
  content       String
  targetRoles   String[]  @map("target_roles")
  priority      String    @default("normal") @db.VarChar(20)
  status        String    @default("active") @db.VarChar(20)
  expiresAt     DateTime? @map("expires_at")
  createdBy     String?   @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  createdByUser User?     @relation("CreatedBy", fields: [createdBy], references: [id])
  school        School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([createdAt])
  @@map("announcements")
}

model LeaveRequest {
  id             String        @id @default(uuid())
  schoolId       String        @map("school_id")
  userId         String        @map("user_id")
  roleCode       String        @map("role_code") @db.VarChar(30)
  startDate      DateTime      @map("start_date") @db.Date
  endDate        DateTime      @map("end_date") @db.Date
  reason         String
  status         String        @default("pending") @db.VarChar(20)
  reviewedBy     String?       @map("reviewed_by")
  reviewedAt     DateTime?     @map("reviewed_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  currentStep    Int           @default(0) @map("current_step")
  leaveType      String        @default("other") @map("leave_type") @db.VarChar(50)
  studentId      String?       @map("student_id")
  actions        LeaveAction[]
  reviewedByUser User?         @relation("ReviewedBy", fields: [reviewedBy], references: [id])
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student?      @relation(fields: [studentId], references: [id])
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([userId])
  @@map("leave_requests")
}

model LeaveAction {
  id          String       @id @default(uuid())
  leaveId     String       @map("leave_id")
  actorUserId String?      @map("actor_user_id")
  stepOrder   Int          @map("step_order")
  action      String       @db.VarChar(20)
  comment     String?
  createdAt   DateTime     @default(now()) @map("created_at")
  actor       User?        @relation("LeaveActionActor", fields: [actorUserId], references: [id])
  leave       LeaveRequest @relation(fields: [leaveId], references: [id], onDelete: Cascade)

  @@index([leaveId])
  @@map("leave_actions")
}

model LeaveWorkflow {
  id        String              @id @default(uuid())
  schoolId  String              @map("school_id")
  type      String              @db.VarChar(20)
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at")
  steps     LeaveWorkflowStep[]
  school    School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, type])
  @@index([schoolId])
  @@map("leave_workflows")
}

model LeaveWorkflowStep {
  id             String        @id @default(uuid())
  workflowId     String        @map("workflow_id")
  stepOrder      Int           @map("step_order")
  label          String        @db.VarChar(100)
  approverRole   String?       @map("approver_role") @db.VarChar(30)
  approverUserId String?       @map("approver_user_id")
  emailEnabled   Boolean       @default(false) @map("email_enabled")
  notifyEnabled  Boolean       @default(true)  @map("notify_enabled")
  notifyMessage  String?       @map("notify_message") @db.VarChar(300)
  createdAt      DateTime      @default(now()) @map("created_at")
  workflow       LeaveWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stepOrder])
  @@index([workflowId])
  @@map("leave_workflow_steps")
}

model TeacherLeaveBalance {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  teacherId    String   @map("teacher_id")
  leaveType    String   @map("leave_type") @db.VarChar(50)
  academicYear String   @default("2024-25") @map("academic_year") @db.VarChar(9)
  totalDays    Int      @default(0) @map("total_days")
  usedDays     Int      @default(0) @map("used_days")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher      Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([schoolId, teacherId, leaveType, academicYear])
  @@index([schoolId, teacherId])
  @@map("teacher_leave_balances")
}

model StudentQuery {
  id              String    @id @default(uuid())
  schoolId        String    @map("school_id")
  studentId       String?   @map("student_id")
  parentId        String?   @map("parent_id")
  subject         String    @db.VarChar(200)
  message         String
  status          String    @default("open") @db.VarChar(20)
  response        String?
  respondedBy     String?   @map("responded_by")
  respondedAt     DateTime? @map("responded_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  parent          Parent?   @relation(fields: [parentId], references: [id])
  respondedByUser User?     @relation("RespondedBy", fields: [respondedBy], references: [id])
  school          School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student         Student?  @relation(fields: [studentId], references: [id])

  @@index([schoolId, status])
  @@index([parentId])
  @@map("queries")
}

model SupportQuery {
  id           String   @id @default(uuid())
  ticketNo     String   @unique @map("ticket_no") @db.VarChar(20)
  schoolId     String   @map("school_id")
  raisedById   String   @map("raised_by_id")
  raisedByRole String   @map("raised_by_role") @db.VarChar(30)
  queryType    String?  @map("query_type") @db.VarChar(50)
  subject      String   @db.VarChar(200)
  description  String
  status       String   @default("open") @db.VarChar(20)
  attachments  String[]
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school   School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  raisedBy User                 @relation("SupportQueryRaisedBy", fields: [raisedById], references: [id])
  replies  SupportQueryReply[]

  @@index([schoolId, status])
  @@index([raisedById])
  @@map("support_queries")
}

model SupportQueryReply {
  id        String   @id @default(uuid())
  queryId   String   @map("query_id")
  userId    String   @map("user_id")
  message   String
  createdAt DateTime @default(now()) @map("created_at")

  query SupportQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)
  user  User         @relation("SupportQueryReplyUser", fields: [userId], references: [id])

  @@index([queryId])
  @@map("support_query_replies")
}

model TransportRoute {
  id               String   @id @default(uuid())
  schoolId         String   @map("school_id")
  name             String   @db.VarChar(100)
  driverName       String?  @map("driver_name") @db.VarChar(100)
  driverPhone      String?  @map("driver_phone") @db.VarChar(20)
  vehicleNo        String?  @map("vehicle_no") @db.VarChar(20)
  capacity         Int?
  morningDeparture String?  @map("morning_departure") @db.VarChar(10)
  eveningDeparture String?  @map("evening_departure") @db.VarChar(10)
  stops            Json?
  createdAt        DateTime @default(now()) @map("created_at")
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("transport_routes")
}

model Vendor {
  id          String            @id @default(uuid())
  userId      String            @unique @map("user_id")
  companyName String            @map("company_name") @db.VarChar(200)
  gstNo       String?           @map("gst_no") @db.VarChar(20)
  address     String?
  createdAt   DateTime          @default(now()) @map("created_at")
  inventory   VendorInventory[]
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("vendors")
}

model VendorInventory {
  id          String   @id @default(uuid())
  vendorId    String   @map("vendor_id")
  schoolId    String?  @map("school_id")
  name        String   @db.VarChar(200)
  description String?
  category    String   @db.VarChar(30)
  price       Decimal  @db.Decimal(10, 2)
  quantity    Int      @default(0)
  unit        String   @default("piece") @db.VarChar(20)
  imageUrl    String?  @map("image_url")
  status      String   @default("available") @db.VarChar(20)
  createdAt   DateTime @default(now()) @map("created_at")
  school      School?  @relation(fields: [schoolId], references: [id])
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("vendor_inventory")
}

model Consultant {
  id              String               @id @default(uuid())
  userId          String               @unique @map("user_id")
  specialization  String?
  bio             String?
  qualifications  String?
  experienceYears Int?                 @map("experience_years")
  createdAt       DateTime             @default(now()) @map("created_at")
  contracts       ConsultantContract[]
  sessions        ConsultantSession[]
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("consultants")
}

model ConsultantContract {
  id            String     @id @default(uuid())
  consultantId  String     @map("consultant_id")
  schoolId      String     @map("school_id")
  contractNo    String     @map("contract_no") @db.VarChar(50)
  startDate     DateTime   @map("start_date") @db.Date
  endDate       DateTime   @map("end_date") @db.Date
  contractValue Decimal?   @map("contract_value") @db.Decimal(12, 2)
  status        String     @default("active") @db.VarChar(20)
  createdAt     DateTime   @default(now()) @map("created_at")
  consultant    Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  school        School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("consultant_contracts")
}

model ConsultantSession {
  id              String     @id @default(uuid())
  consultantId    String     @map("consultant_id")
  schoolId        String     @map("school_id")
  title           String     @db.VarChar(200)
  description     String?
  sessionType     String     @default("group") @map("session_type") @db.VarChar(30)
  targetGrades    String[]   @map("target_grades")
  sessionDate     DateTime   @map("session_date")
  durationMinutes Int        @default(60) @map("duration_minutes")
  maxParticipants Int?       @map("max_participants")
  status          String     @default("scheduled") @db.VarChar(20)
  meetingLink     String?    @map("meeting_link")
  createdAt       DateTime   @default(now()) @map("created_at")
  consultant      Consultant @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  school          School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("consultant_sessions")
}

model ComplianceItem {
  id          String               @id @default(uuid())
  schoolId    String               @map("school_id")
  category    String               @db.VarChar(50)
  title       String               @db.VarChar(200)
  description String?
  status      String               @default("pending") @db.VarChar(20)
  dueDate     DateTime?            @map("due_date") @db.Date
  notes       String?
  assignedTo  String?              @map("assigned_to")
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @default(now()) @updatedAt @map("updated_at")
  updatedBy   String?              @map("updated_by")
  documents   ComplianceDocument[]
  school      School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, category])
  @@index([schoolId, status])
  @@map("compliance_items")
}

model ComplianceDocument {
  id         String         @id @default(uuid())
  itemId     String         @map("item_id")
  schoolId   String         @map("school_id")
  name       String         @db.VarChar(200)
  fileUrl    String         @map("file_url")
  fileType   String?        @map("file_type") @db.VarChar(50)
  uploadedBy String         @map("uploaded_by")
  uploadedAt DateTime       @default(now()) @map("uploaded_at")
  item       ComplianceItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@map("compliance_documents")
}

model OtpVerification {
  id        String   @id @default(uuid())
  phone     String   @db.VarChar(20)
  email     String?  @db.VarChar(100)
  otp       String   @db.VarChar(6)
  expiresAt DateTime @map("expires_at")
  verified  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([phone])
  @@map("otp_verifications")
}

model AdmissionWorkflow {
  id           String                  @id @default(uuid())
  schoolId     String                  @map("school_id")
  name         String                  @db.VarChar(100)
  isActive     Boolean                 @default(true) @map("is_active")
  createdAt    DateTime                @default(now()) @map("created_at")
  applications AdmissionApplication[]
  steps        AdmissionWorkflowStep[]
  school       School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@map("admission_workflows")
}

model AdmissionWorkflowStep {
  id             String            @id @default(uuid())
  workflowId     String            @map("workflow_id")
  stepOrder      Int               @map("step_order")
  label          String            @db.VarChar(100)
  approverRole   String            @map("approver_role") @db.VarChar(30)
  emailEnabled   Boolean           @default(false) @map("email_enabled")
  notifyEnabled  Boolean           @default(true)  @map("notify_enabled")
  notifyMessage  String?           @map("notify_message") @db.VarChar(300)
  isFinal        Boolean           @default(false) @map("is_final")
  createdAt      DateTime          @default(now()) @map("created_at")
  workflow       AdmissionWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stepOrder])
  @@index([workflowId])
  @@map("admission_workflow_steps")
}

model AdmissionApplication {
  id              String             @id @default(uuid())
  schoolId        String             @map("school_id")
  workflowId      String?            @map("workflow_id")
  parentName      String             @map("parent_name") @db.VarChar(200)
  parentPhone     String             @map("parent_phone") @db.VarChar(20)
  parentEmail     String             @map("parent_email") @db.VarChar(100)
  parentUserId    String?            @map("parent_user_id")
  currentStep     Int                @default(0) @map("current_step")
  status          String             @default("submitted") @db.VarChar(20)
  riskScore       Int                @default(0) @map("risk_score")
  validationFlags Json?              @map("validation_flags")
  submittedAt     DateTime           @default(now()) @map("submitted_at")
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at")
  actions         AdmissionAction[]
  parentUser      User?              @relation("ApplicationParentUser", fields: [parentUserId], references: [id])
  school          School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workflow        AdmissionWorkflow? @relation(fields: [workflowId], references: [id])
  children        AdmissionChild[]

  @@index([schoolId, status])
  @@index([parentEmail])
  @@index([submittedAt])
  @@map("admission_applications")
}

model AdmissionChild {
  id             String               @id @default(uuid())
  applicationId  String               @map("application_id")
  firstName      String               @map("first_name") @db.VarChar(100)
  lastName       String               @map("last_name") @db.VarChar(100)
  dateOfBirth    DateTime             @map("date_of_birth") @db.Date
  gender         String               @db.VarChar(10)
  aadhaarNo      String?              @map("aadhaar_no") @db.VarChar(12)
  classApplying  String               @map("class_applying") @db.VarChar(30)
  previousSchool String?              @map("previous_school") @db.VarChar(200)
  studentId      String?              @unique @map("student_id")
  createdAt      DateTime             @default(now()) @map("created_at")
  application    AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  student        Student?             @relation("CreatedFromAdmission", fields: [studentId], references: [id])

  @@index([applicationId])
  @@index([aadhaarNo])
  @@map("admission_children")
}

model AdmissionAction {
  id            String               @id @default(uuid())
  applicationId String               @map("application_id")
  actorUserId   String?              @map("actor_user_id")
  stepOrder     Int?                 @map("step_order")
  action        String               @db.VarChar(20)
  comment       String?
  createdAt     DateTime             @default(now()) @map("created_at")
  actorUser     User?                @relation("AdmissionActionActor", fields: [actorUserId], references: [id])
  application   AdmissionApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("admission_actions")
}

model LeaveTypeMaster {
  id           String               @id @default(uuid())
  schoolId     String               @map("school_id")
  name         String               @db.VarChar(100)
  code         String               @db.VarChar(30)
  applicableTo String[]             @map("applicable_to")
  isActive     Boolean              @default(true) @map("is_active")
  createdAt    DateTime             @default(now()) @map("created_at")
  policies     LeaveBalancePolicy[]
  school       School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("leave_type_masters")
}

model LeaveBalancePolicy {
  id           String          @id @default(uuid())
  schoolId     String          @map("school_id")
  leaveTypeId  String          @map("leave_type_id")
  roleCode     String          @map("role_code") @db.VarChar(30)
  daysPerYear  Int             @default(0) @map("days_per_year")
  carryForward Boolean         @default(false) @map("carry_forward")
  maxCarryDays Int             @default(0) @map("max_carry_days")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @default(now()) @updatedAt @map("updated_at")
  leaveType    LeaveTypeMaster @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  school       School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, leaveTypeId, roleCode])
  @@index([schoolId, roleCode])
  @@map("leave_balance_policies")
}

model HolidayCalendar {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  academicYear String   @map("academic_year") @db.VarChar(9)
  date         DateTime @db.Date
  name         String   @db.VarChar(200)
  type         String   @default("mandatory") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at")
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, date])
  @@index([schoolId, academicYear])
  @@map("holiday_calendar")
}

model Timetable {
  id           String          @id @default(uuid())
  schoolId     String          @map("school_id")
  classId      String          @map("class_id")
  academicYear String          @default("2025-2026") @map("academic_year") @db.VarChar(9)
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @default(now()) @updatedAt @map("updated_at")
  slots        TimetableSlot[]
  class        Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  school       School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classId, academicYear])
  @@index([schoolId])
  @@map("timetables")
}

model TimetableSlot {
  id          String    @id @default(uuid())
  timetableId String    @map("timetable_id")
  dayOfWeek   Int       @map("day_of_week")
  periodNo    Int       @map("period_no")
  startTime   String    @map("start_time") @db.VarChar(10)
  endTime     String    @map("end_time") @db.VarChar(10)
  subject     String    @db.VarChar(100)
  teacherId   String?   @map("teacher_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  teacher     Teacher?  @relation(fields: [teacherId], references: [id])
  timetable   Timetable @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@unique([timetableId, dayOfWeek, periodNo])
  @@map("timetable_slots")
}

model MenuPermission {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  roleCode  String   @map("role_code") @db.VarChar(30)
  menuKey   String   @map("menu_key")  @db.VarChar(50)
  enabled   Boolean  @default(true)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, roleCode, menuKey])
  @@index([schoolId, roleCode])
  @@map("menu_permissions")
}
