model CountryMaster {
  id        String                 @id @default(uuid())
  schoolId  String                 @map("school_id")
  name      String                 @db.VarChar(100)
  code      String                 @db.VarChar(3)
  isActive  Boolean                @default(true) @map("is_active")
  sortOrder Int                    @default(0) @map("sort_order")
  createdAt DateTime               @default(now()) @map("created_at")
  school    School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  states    StateMaster[]
  locations SchoolLocationMaster[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("country_masters")
}

model StateMaster {
  id        String                 @id @default(uuid())
  schoolId  String                 @map("school_id")
  countryId String                 @map("country_id")
  name      String                 @db.VarChar(100)
  code      String?                @db.VarChar(10)
  isActive  Boolean                @default(true) @map("is_active")
  sortOrder Int                    @default(0) @map("sort_order")
  createdAt DateTime               @default(now()) @map("created_at")
  country   CountryMaster          @relation(fields: [countryId], references: [id])
  school    School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  districts DistrictMaster[]
  locations SchoolLocationMaster[]

  @@unique([schoolId, countryId, name])
  @@index([schoolId])
  @@index([countryId])
  @@map("state_masters")
}

model DistrictMaster {
  id        String                 @id @default(uuid())
  schoolId  String                 @map("school_id")
  stateId   String                 @map("state_id")
  name      String                 @db.VarChar(100)
  isActive  Boolean                @default(true) @map("is_active")
  sortOrder Int                    @default(0) @map("sort_order")
  createdAt DateTime               @default(now()) @map("created_at")
  school    School                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  state     StateMaster            @relation(fields: [stateId], references: [id])
  locations SchoolLocationMaster[]

  @@unique([schoolId, stateId, name])
  @@index([schoolId])
  @@index([stateId])
  @@map("district_masters")
}

model SchoolLocationMaster {
  id         String          @id @default(uuid())
  schoolId   String          @map("school_id")
  address    String
  city       String?         @db.VarChar(100)
  pincode    String?         @db.VarChar(10)
  countryId  String?         @map("country_id")
  stateId    String?         @map("state_id")
  districtId String?         @map("district_id")
  isActive   Boolean         @default(true) @map("is_active")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @default(now()) @updatedAt @map("updated_at")
  school     School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  country    CountryMaster?  @relation(fields: [countryId], references: [id])
  state      StateMaster?    @relation(fields: [stateId], references: [id])
  district   DistrictMaster? @relation(fields: [districtId], references: [id])

  @@index([schoolId])
  @@map("school_location_masters")
}

model SchoolHierarchyMaster {
  id        String                  @id @default(uuid())
  schoolId  String                  @map("school_id")
  name      String                  @db.VarChar(100)
  level     Int
  parentId  String?                 @map("parent_id")
  isActive  Boolean                 @default(true) @map("is_active")
  createdAt DateTime                @default(now()) @map("created_at")
  school    School                  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  parent    SchoolHierarchyMaster?  @relation("HierarchyTree", fields: [parentId], references: [id])
  children  SchoolHierarchyMaster[] @relation("HierarchyTree")

  @@index([schoolId])
  @@map("school_hierarchy_masters")
}

model ExamTypeMaster {
  id           String              @id @default(uuid())
  schoolId     String              @map("school_id")
  name         String              @db.VarChar(100)
  code         String              @db.VarChar(30)
  termOrder    Int                 @default(0) @map("term_order")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")
  school       School              @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  gradingTypes GradingTypeMaster[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("exam_type_masters")
}

model GradingTypeMaster {
  id          String         @id @default(uuid())
  schoolId    String         @map("school_id")
  examTypeId  String         @map("exam_type_id")
  grade       String         @db.VarChar(10)
  minPercent  Decimal        @map("min_percent") @db.Decimal(5, 2)
  maxPercent  Decimal        @map("max_percent") @db.Decimal(5, 2)
  gradePoints Decimal?       @map("grade_points") @db.Decimal(4, 2)
  description String?        @db.VarChar(100)
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  school      School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  examType    ExamTypeMaster @relation(fields: [examTypeId], references: [id], onDelete: Cascade)

  @@unique([schoolId, examTypeId, grade])
  @@index([schoolId])
  @@map("grading_type_masters")
}

model AnnouncementTypeMaster {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  name      String   @db.VarChar(100)
  code      String   @db.VarChar(30)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("announcement_type_masters")
}

model ContentTypeMaster {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  formName  String   @map("form_name") @db.VarChar(100)
  fieldSlot String   @map("field_slot") @db.VarChar(30)
  fieldType String   @default("text") @map("field_type") @db.VarChar(20)
  label     String   @db.VarChar(100)
  options   String[]
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, formName, fieldSlot])
  @@index([schoolId, formName])
  @@map("content_type_masters")
}

// ── Generic Workflow Engine (Attendance, Fee, Query-Parents, Query-SchoolAdmin) ──

model GenericWorkflow {
  id           String                @id @default(uuid())
  schoolId     String                @map("school_id")
  workflowType String                @map("workflow_type") @db.VarChar(50)
  // roleCode is used for workflows that are role-specific (e.g. leave)
  roleCode     String?               @map("role_code") @db.VarChar(30)
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  school       School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  stages       GenericWorkflowStage[]

  @@unique([schoolId, workflowType, roleCode])
  @@index([schoolId])
  @@map("generic_workflows")
}

model GenericWorkflowStage {
  id             String          @id @default(uuid())
  workflowId     String          @map("workflow_id")
  stageOrder     Int             @map("stage_order")
  stageName      String          @map("stage_name") @db.VarChar(100)
  initiatorRole  String?         @map("initiator_role") @db.VarChar(30)
  approverRole   String?         @map("approver_role") @db.VarChar(30)
  approverUserId String?         @map("approver_user_id")
  systemTrigger  String?         @map("system_trigger") @db.VarChar(300)
  isFinal        Boolean         @default(false) @map("is_final")
  emailEnabled   Boolean         @default(false) @map("email_enabled")
  notifyEnabled  Boolean         @default(true)  @map("notify_enabled")
  notifyMessage  String?         @map("notify_message") @db.VarChar(300)
  createdAt      DateTime        @default(now()) @map("created_at")
  workflow       GenericWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stageOrder])
  @@index([workflowId])
  @@map("generic_workflow_stages")
}
