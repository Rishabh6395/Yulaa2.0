  label            String            @db.VarChar(100)
  initiatorRole    String?           @map("initiator_role")   @db.VarChar(30)
  approverRole     String            @map("approver_role")    @db.VarChar(30)
  systemTrigger    String?           @map("system_trigger")   @db.VarChar(300)
  emailEnabled     Boolean           @default(false) @map("email_enabled")
  notifyEnabled    Boolean           @default(true)  @map("notify_enabled")
  notifyMessage    String?           @map("notify_message")   @db.VarChar(300)
  isFinal          Boolean           @default(false) @map("is_final")
  checklistItems   Json?             @map("checklist_items")
  // SPOC: point-of-contact user who gets visibility at this step
  spocUserId       String?           @map("spoc_user_id")
  // Payment: applicant must pay before this step can be approved
  paymentRequired  Boolean           @default(false) @map("payment_required")
  paymentGateway   String?           @map("payment_gateway")  @db.VarChar(30)
  paymentAmountOverride Decimal?     @map("payment_amount_override") @db.Decimal(10, 2)
