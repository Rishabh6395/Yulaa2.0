// ─── Letter / Invoice Templates ───────────────────────────────────────────────
model LetterTemplate {
  id           String   @id @default(uuid())
  schoolId     String?  @map("school_id")
  name         String   @db.VarChar(200)
  templateType String   @default("fee_invoice") @map("template_type") @db.VarChar(50)
  htmlContent  String
  isDefault    Boolean  @default(false) @map("is_default")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")
  school       School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, templateType])
  @@map("letter_templates")
}

// ─── Form Configuration ────────────────────────────────────────────────────────
// Stores per-school, per-form, per-role field visibility rules.
