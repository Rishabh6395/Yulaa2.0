}

model AdmissionApplication {
  id                  String             @id @default(uuid())
  schoolId            String             @map("school_id")
  workflowId          String?            @map("workflow_id")
  parentName          String             @map("parent_name") @db.VarChar(200)
  parentPhone         String             @map("parent_phone") @db.VarChar(20)
  parentEmail         String             @map("parent_email") @db.VarChar(100)
  parentUserId        String?            @map("parent_user_id")
  currentStep         Int                @default(0) @map("current_step")
  status              String             @default("submitted") @db.VarChar(20)
  riskScore           Int                @default(0) @map("risk_score")
  validationFlags     Json?              @map("validation_flags")
  residentialAddress  String?            @map("residential_address")
  permanentAddress    String?            @map("permanent_address")
  // RTE / EWS quota
  isRte               Boolean            @default(false) @map("is_rte")
  rteDocuments        Json?              @map("rte_documents")   // [{type, url}]
  // Sibling preference
  siblingStudentId    String?            @map("sibling_student_id")
  // Waitlist
  waitlistPosition    Int?               @map("waitlist_position")
  waitlistedAt        DateTime?          @map("waitlisted_at")
  // Aadhaar dedup (store hash only, never raw)
  parentAadhaarHash   String?            @map("parent_aadhaar_hash") @db.VarChar(64)
  // Custom fields defined by super admin via ContentTypeMaster
  customFieldValues   Json?              @map("custom_field_values")
  submittedAt         DateTime           @default(now()) @map("submitted_at")
  updatedAt           DateTime           @default(now()) @updatedAt @map("updated_at")

  actions              AdmissionAction[]
  checklistCompletions AdmissionChecklistCompletion[]
  stepAssignments      AdmissionStepAssignment[]
  parentUser           User?              @relation("ApplicationParentUser", fields: [parentUserId], references: [id])
  school               School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  workflow             AdmissionWorkflow? @relation(fields: [workflowId], references: [id])
  children             AdmissionChild[]
  transferCertificate  TransferCertificate?

  @@index([schoolId, status])
  @@index([parentEmail])
  @@index([submittedAt])
  @@index([schoolId, waitlistPosition])
  @@map("admission_applications")
}

