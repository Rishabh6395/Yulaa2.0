  startTime String   @map("start_time") @db.VarChar(10)
  endTime   String   @map("end_time") @db.VarChar(10)
  maxMarks  Int      @map("max_marks")
  venue     String?  @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")
  exam      Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  class     Class    @relation(fields: [classId], references: [id])

  @@unique([examId, classId, subject])
  @@index([examId])
  @@map("exam_timetable_entries")
}

model ExamResult {
  id            String   @id @default(uuid())
  examId        String   @map("exam_id")
  studentId     String   @map("student_id")
  subject       String   @db.VarChar(100)
  marksObtained Decimal  @map("marks_obtained") @db.Decimal(6, 2)
  maxMarks      Int      @map("max_marks")
  grade         String?  @db.VarChar(5)
  remarks       String?  @db.VarChar(200)
  enteredById   String   @map("entered_by_id")
  approved      Boolean  @default(false)
  approvedById  String?  @map("approved_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([examId, studentId, subject])
  @@index([examId])
  @@index([studentId])
  @@map("exam_results")
