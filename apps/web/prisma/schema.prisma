  @@index([schoolId])
  @@index([examId])
  @@index([studentId])
  @@map("exam_results")
}

// ─── Performance Risk Configuration ─────────────────────────────────────────
// Configurable by super_admin (global, schoolId=null) or school_admin (per school).
// Grade-specific rules override the school-wide default (grade=null).
model PerformanceRiskConfig {
  id                  String   @id @default(uuid())
  schoolId            String?  @map("school_id")           // null = global default
  grade               String?  @db.VarChar(20)             // null = all grades
  minMarksPct         Int      @default(40) @map("min_marks_pct")
  minAttendancePct    Int      @default(75) @map("min_attendance_pct")
  minHomeworkPct      Int      @default(60) @map("min_homework_pct")
  weightMarks         Int      @default(40) @map("weight_marks")
  weightAttendance    Int      @default(35) @map("weight_attendance")
  weightHomework      Int      @default(25) @map("weight_homework")
  highRiskThreshold   Int      @default(60) @map("high_risk_threshold")
  mediumRiskThreshold Int      @default(30) @map("medium_risk_threshold")
  createdById         String   @map("created_by_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at")
  school              School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, grade])
  @@index([schoolId])
  @@map("performance_risk_configs")
}

// ─── KPI Configuration ────────────────────────────────────────────────────────

model SchoolKpiConfig {
  id               String   @id @default(uuid())
  schoolId         String   @map("school_id")
  kpiCode          String   @map("kpi_code") @db.VarChar(60)
  isEnabled        Boolean  @default(true) @map("is_enabled")
  targetValue      Decimal? @map("target_value") @db.Decimal(8, 2)
  targetDirection  String   @default("above") @map("target_direction") @db.VarChar(10)
  academicYear     String   @map("academic_year") @db.VarChar(9)
  visibleToRoles   String?  @map("visible_to_roles") @db.Text  // JSON array of role codes; null = use KPI definition default
  formulaParams    String?  @map("formula_params") @db.Text    // JSON object; school-specific formula thresholds
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")
  school           School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, kpiCode, academicYear])
  @@index([schoolId, academicYear])
  @@map("school_kpi_configs")
}

// ─── Report Cards ─────────────────────────────────────────────────────────────
// Sent by school_admin / principal / teacher to parents.
// Data is snapshotted at send time so the report is immutable.

model ReportCard {
  id                    String    @id @default(uuid())
  schoolId              String    @map("school_id")
  studentId             String    @map("student_id")
  classId               String?   @map("class_id")
  academicYear          String    @map("academic_year") @db.VarChar(9)
  term                  String    @db.VarChar(60)
  cycleId               String?   @map("cycle_id")
  sentById              String    @map("sent_by_id")
  sentAt                DateTime  @default(now()) @map("sent_at")
  viewedAt              DateTime? @map("viewed_at")
  parentAcknowledgedAt  DateTime? @map("parent_acknowledged_at")
  // Immutable JSON snapshots of data at send time
  academicData          String?   @map("academic_data")   @db.Text
  attendanceData        String?   @map("attendance_data") @db.Text
  behaviorData          String?   @map("behavior_data")   @db.Text
  ecoData               String?   @map("eco_data")        @db.Text  // extracurricular snapshot
  // Scores and ratings
  compositeScore        Decimal?  @map("composite_score") @db.Decimal(5, 2)
  overallRating         String?   @map("overall_rating")  @db.VarChar(30)
  academicRating        String?   @map("academic_rating")   @db.VarChar(30)
  attendanceRating      String?   @map("attendance_rating") @db.VarChar(30)
  behaviorRating        String?   @map("behavior_rating")   @db.VarChar(30)
  ecoRating             String?   @map("eco_rating")        @db.VarChar(30)
  // Remarks
  teacherRemarks        String?   @map("teacher_remarks")      @db.Text
  principalRemarks      String?   @map("principal_remarks")    @db.Text
  aiGeneratedRemarks    String?   @map("ai_generated_remarks") @db.Text
  templateId            String?   @map("template_id")
  studentSnapshot       String?   @map("student_snapshot")     @db.Text  // immutable JSON: name/photo/class/admissionNo
  status                String    @default("draft") @db.VarChar(30)  // draft | principal_approved | published | parent_acknowledged
  publishedAt           DateTime? @map("published_at")

  school  School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sentBy  User             @relation("ReportCardSentBy", fields: [sentById], references: [id])
  cycle   PerformanceCycle? @relation(fields: [cycleId], references: [id])

  @@index([schoolId, academicYear])
  @@index([studentId, academicYear])
  @@index([cycleId])
  @@map("report_cards")
}

// ─── KPI Rating Config ────────────────────────────────────────────────────────
// Per-school configurable rating thresholds for report card sections.
// segment: 'academic' | 'attendance' | 'behavior'

model KpiRatingConfig {
  id              String   @id @default(uuid())
  schoolId        String   @map("school_id")
  segment         String   @db.VarChar(20)  // 'academic' | 'attendance' | 'behavior' | 'extracurricular' | 'composite'
  // For academic & attendance: score/percentage thresholds (lower bound for each band)
  excellentMin    Int      @default(90)  @map("excellent_min")
  goodMin         Int      @default(75)  @map("good_min")
  averageMin      Int      @default(60)  @map("average_min")
  belowAverageMin Int      @default(40)  @map("below_average_min")
  // For behavior: negative-incident count thresholds (upper bound for each band)
  behExcellentMax Int      @default(0)   @map("beh_excellent_max")
  behGoodMax      Int      @default(2)   @map("beh_good_max")
  behAverageMax   Int      @default(5)   @map("beh_average_max")
  behBelowAvgMax  Int      @default(10)  @map("beh_below_avg_max")
  // ECO (extracurricular) point thresholds — used when segment='extracurricular'
  ecoExcellentMin Int      @default(85)  @map("eco_excellent_min")
  ecoGoodMin      Int      @default(70)  @map("eco_good_min")
  ecoAverageMin   Int      @default(50)  @map("eco_average_min")
  ecoBelowAvgMin  Int      @default(30)  @map("eco_below_avg_min")
  // Composite weights (sum must equal 100, used when segment='composite')
  weightAcademic      Int  @default(40)  @map("weight_academic")
  weightAttendance    Int  @default(30)  @map("weight_attendance")
  weightBehavior      Int  @default(20)  @map("weight_behavior")
  weightEco           Int  @default(10)  @map("weight_eco")
  // Custom rating labels (JSON: {"excellent":"Outstanding","good":"Good",...})
  ratingLabels    String?  @map("rating_labels") @db.VarChar(500)
  // Rating scale with colors — [{min,max,label,color}] used for composite output
  ratingScale     Json?    @map("rating_scale")
  createdById     String   @map("created_by_id")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")
  school          School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, segment])
  @@map("kpi_rating_configs")
}

// ─── School Inventory ─────────────────────────────────────────────────────────
