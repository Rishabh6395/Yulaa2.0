// ─── Exam Management ─────────────────────────────────────────────────────────
model Exam {
  id                 String               @id @default(uuid())
  schoolId           String               @map("school_id")
  title              String               @db.VarChar(200)
  examType           String               @map("exam_type") @db.VarChar(50)
  subject            String?              @db.VarChar(100)
  academicYear       String               @map("academic_year") @db.VarChar(9)
  classId            String?              @map("class_id")
  performanceCycleId String?              @map("performance_cycle_id")
  createdByRole      String?              @map("created_by_role") @db.VarChar(30)
  approvedById       String?              @map("approved_by_id")
  startDate          DateTime             @map("start_date") @db.Date
  endDate            DateTime             @map("end_date") @db.Date
  status             String               @default("scheduled") @db.VarChar(20)
  gradingType        String               @default("percentage") @map("grading_type") @db.VarChar(20)
  maxMarks           Int                  @default(100) @map("max_marks")
  passingMarks       Int                  @default(35) @map("passing_marks")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @default(now()) @updatedAt @map("updated_at")
  entries            ExamTimetableEntry[]
  results            ExamResult[]
