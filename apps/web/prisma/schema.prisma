// ─── Form Configuration ────────────────────────────────────────────────────────
// Stores per-school, per-form, per-role field visibility rules.
// role: 'applicant' (public /apply page) | 'admin' | 'teacher' | 'parent' | 'student'
model FormConfig {
  id         String   @id @default(uuid())
  schoolId   String   @map("school_id")
  formId     String   @map("form_id") @db.VarChar(50)
  role       String   @default("applicant") @db.VarChar(30)
  fieldRules Json     @map("field_rules")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
  school     School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, formId, role])
  @@index([schoolId, formId])
  @@map("form_configs")
}

// ─── Phase 1 Masters ────────────────────────────────────────────────────────

model GenderMaster {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  name      String   @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, name])
  @@index([schoolId])
  @@map("gender_masters")
}

model BloodGroupMaster {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
