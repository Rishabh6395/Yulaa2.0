generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model School {
  id                    String                 @id @default(uuid())
  name                  String                 @db.VarChar(200)
  address               String?
  email                 String?                @unique @db.VarChar(100)
  phone                 String?                @db.VarChar(20)
  logoUrl               String?                @map("logo_url")
  status                String                 @default("active") @db.VarChar(20)
  subscriptionPlan      String                 @default("basic") @map("subscription_plan") @db.VarChar(20)
  createdAt             DateTime               @default(now()) @map("created_at")
  admissionFeeAmt       Decimal?               @map("admission_fee_amt") @db.Decimal(10, 2)
  admissionsOpen        Boolean                @default(false) @map("admissions_open")
  city                  String?                @db.VarChar(100)
  description           String?
  facilities            String[]
  state                 String?                @db.VarChar(100)
  website               String?                @db.VarChar(200)
  boardType             String?                @map("board_type") @db.VarChar(30)
  isDefault                Boolean                @default(false) @map("is_default")
  attendanceMode           String                 @default("class") @map("attendance_mode") @db.VarChar(20)
  attendancePunchEnabled   Boolean                @default(false) @map("attendance_punch_enabled")
  latitude                 Float?
  longitude                Float?
  allowExternalConsultant  Boolean                @default(false) @map("allow_external_consultant")
  allowExternalVendor      Boolean                @default(false) @map("allow_external_vendor")
  onlineClassEnabled       Boolean                @default(true)  @map("online_class_enabled")
  courseEnabled            Boolean                @default(false) @map("course_enabled")
  allowedPlatforms         String[]               @default([])    @map("allowed_platforms")
  // Admission-specific settings (JSON): { allowTaskReassign, taskReassignRoles, spocEnabled, defaultSpocUserId }
  admissionSettings        Json?                  @map("admission_settings")
  admissionApplications AdmissionApplication[]
  admissionWorkflows    AdmissionWorkflow[]
  announcements         Announcement[]
  attendance            Attendance[]
  classes               Class[]
  complianceItems       ComplianceItem[]
  consultantContracts   ConsultantContract[]
  consultantSessions    ConsultantSession[]
  feeInvoices           FeeInvoice[]
  feeStructures         FeeStructure[]
  holidayCalendar       HolidayCalendar[]
  homework              Homework[]
  leaveBalancePolicies  LeaveBalancePolicy[]
  leaveRequests         LeaveRequest[]
  gradeMasters          GradeMaster[]
  leaveTypeMasters      LeaveTypeMaster[]
  leaveWorkflows        LeaveWorkflow[]
  queries               StudentQuery[]
  supportQueries        SupportQuery[]
  students              Student[]
  teacherLeaveBalances  TeacherLeaveBalance[]
  teachers              Teacher[]
  menuPermissions         MenuPermission[]
  timetables              Timetable[]
  sessionBookings         SessionBooking[]
  onlineClasses           OnlineClass[]
  courses                 Course[]
  transportRoutes       TransportRoute[]
  transportBuses        TransportBus[]
  transportRides        TransportRide[]
  userRoles             UserRole[]
  vendorInventory       VendorInventory[]
  // New modules
  schoolEvents          SchoolEvent[]
  syllabusItems         SyllabusItem[]
  exams                 Exam[]
  inventoryItems        InventoryItem[]
  letterTemplates       LetterTemplate[]
  formConfigs           FormConfig[]
  // Phase 1 masters (school-specific)
  genders             GenderMaster[]
  bloodGroups         BloodGroupMaster[]
  qualifications      QualificationMaster[]
  streams             StreamMaster[]
  eventTypes          EventTypeMaster[]
  countries           CountryMaster[]
  states              StateMaster[]
  districts           DistrictMaster[]
  schoolLocations     SchoolLocationMaster[]
  schoolHierarchies   SchoolHierarchyMaster[]
  examTypes           ExamTypeMaster[]
  gradingTypes        GradingTypeMaster[]
  announcementTypes   AnnouncementTypeMaster[]
  contentTypes        ContentTypeMaster[]
  genericWorkflows    GenericWorkflow[]
  genericMasterTypes  GenericMasterType[]
  studentSkillRatings      StudentSkillRating[]
  behaviorIncidents        BehaviorIncident[]
  performanceRiskConfigs   PerformanceRiskConfig[]
  kpiConfigs               SchoolKpiConfig[]
  kpiRatingConfigs         KpiRatingConfig[]
  reportCards              ReportCard[]
  performanceCycles        PerformanceCycle[]
  timingConfigs            SchoolTimingConfig[]
  extracurricularEntries   ExtracurricularEntry[]
  courseRecommendations    CourseRecommendation[]
  examResults              ExamResult[]
  academicYears            AcademicYear[]
  behaviorKpiConfigs       BehaviorKpiConfig[]
  ecoPointsMatrix          EcoPointsMatrix[]
  attendancePeriodSummaries AttendancePeriodSummary[]
  cycleAcademicSummaries   CycleAcademicSummary[]
  attendanceRegularizations AttendanceRegularization[]
  gatePasses               GatePass[]
  feeConcessions           FeeConcession[]
  lateFeeConfigs           LateFeeConfig[]
  transferCertificates     TransferCertificate[]
  earlyWarningLogs         EarlyWarningLog[]
  libraryBooks             LibraryBook[]
  libraryIssues            LibraryIssue[]
  hostelBlocks             HostelBlock[]
  hostelRooms              HostelRoom[]
  hostelAllocations        HostelAllocation[]
  diaryEntries             DiaryEntry[]
  staffSalaryConfigs       StaffSalaryConfig[]
  staffPayrolls            StaffPayroll[]
  boardExamTrackers        BoardExamTracker[]
  subjectChatThreads       SubjectChatThread[]
  riskFlags                RiskFlag[]
  gradingSchemes           GradingScheme[]
  subjectCatalog           SubjectCatalog[]
  yearbookEntries          YearbookEntry[]

  @@map("schools")
}

model Role {
  id          String     @id @default(uuid())
  code        String     @unique @db.VarChar(30)
  displayName String     @map("display_name") @db.VarChar(100)
  description String?
  userRoles   UserRole[]

  @@map("roles")
}

model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique @db.VarChar(100)
  passwordHash          String                 @map("password_hash")
  firstName             String                 @map("first_name") @db.VarChar(100)
  lastName              String                 @map("last_name") @db.VarChar(100)
  phone                 String?                @db.VarChar(20)
  avatarUrl             String?                @map("avatar_url")
  status                String                 @default("active") @db.VarChar(20)
  createdAt             DateTime               @default(now()) @map("created_at")
  mustResetPassword     Boolean                @default(false) @map("must_reset_password")
  admissionActions      AdmissionAction[]          @relation("AdmissionActionActor")
  admissionApplications AdmissionApplication[]     @relation("ApplicationParentUser")
  assignmentsReceived   AdmissionStepAssignment[]  @relation("AssignmentTarget")
  assignmentsMade       AdmissionStepAssignment[]  @relation("AssignmentSource")
  announcements         Announcement[]         @relation("CreatedBy")
  markedAttendance      Attendance[]           @relation("MarkedBy")
  updatedAttendance     Attendance[]           @relation("UpdatedBy")
  consultants           Consultant?
  leaveActions          LeaveAction[]          @relation("LeaveActionActor")
  reviewedLeaves        LeaveRequest[]         @relation("ReviewedBy")
  leaveRequests         LeaveRequest[]
  parents               Parent?
  respondedQueries      StudentQuery[]         @relation("RespondedBy")
  raisedSupportQueries  SupportQuery[]         @relation("SupportQueryRaisedBy")
  supportQueryReplies   SupportQueryReply[]    @relation("SupportQueryReplyUser")
  teachers              Teacher[]
  userRoles             UserRole[]
  vendors               Vendor?
  createdEvents         SchoolEvent[]
  operatedRides         TransportRide[]        @relation("TransportRideEmployee")
  courseEnrollments     CourseEnrollment[]
  reportCardsSent       ReportCard[]           @relation("ReportCardSentBy")
  approvedExams         Exam[]                 @relation("ExamApprovedBy")
  yearbookUploads       YearbookEntry[]        @relation("YearbookUploader")

  @@map("users")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  schoolId  String?  @map("school_id")
  isPrimary Boolean  @default(true) @map("is_primary")
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  school    School?  @relation(fields: [schoolId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([roleId])
  @@index([schoolId])
  @@map("user_roles")
}

model Teacher {
  id              String                @id @default(uuid())
  userId          String                @map("user_id")
  schoolId        String                @map("school_id")
  employeeId      String?               @map("employee_id") @db.VarChar(30)
  designation     String?               @db.VarChar(100)
  department      String?               @db.VarChar(100)
  qualification   String?
  experienceYears Int?                  @map("experience_years")
  joiningDate     DateTime?             @map("joining_date") @db.Date
  classId         String?               @map("class_id")
  status          String                @default("active") @db.VarChar(20)
  createdAt       DateTime              @default(now()) @map("created_at")
  dateOfBirth     DateTime?             @map("date_of_birth") @db.Date
  gender          String?               @db.VarChar(10)
  aadhaarNo       String?               @map("aadhaar_no") @db.VarChar(12)
  panNo           String?               @map("pan_no") @db.VarChar(10)
  category        String?               @db.VarChar(50)
  employmentType  String?               @map("employment_type") @db.VarChar(50)
  designationType String?               @map("designation_type") @db.VarChar(50)
  teacherCert     String?               @map("teacher_cert") @db.VarChar(50)
  languagesKnown  String?               @map("languages_known") @db.VarChar(200)
  pfAccountNo     String?               @map("pf_account_no") @db.VarChar(30)
  bankAccountNo   String?               @map("bank_account_no") @db.VarChar(30)
  bankIfsc        String?               @map("bank_ifsc") @db.VarChar(11)
  ibCertified     Boolean               @default(false) @map("ib_certified")
  workPermitType  String?               @map("work_permit_type") @db.VarChar(50)
  passportNo      String?               @map("passport_no") @db.VarChar(20)
  attendance      Attendance[]
  classes         Class[]
  homework        Homework[]
  leaveBalances   TeacherLeaveBalance[]
  school          School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  timetableSlots       TimetableSlot[]
  timetableLogs        TimetableLog[]
  eventTasks           EventTask[]
  syllabusItems        SyllabusItem[]
  onlineClasses        OnlineClass[]
  taughtCourses        Course[]
  skillRatingsGiven    StudentSkillRating[]
  invigilatedEntries   ExamTimetableEntry[]   @relation("ExamInvigilator")
  libraryIssues        LibraryIssue[]
  salaryConfig         StaffSalaryConfig?
  payrolls             StaffPayroll[]
  subjectChatThreads   SubjectChatThread[]
  diaryEntries         DiaryEntry[]

  @@unique([userId, schoolId])
  @@index([schoolId])
  @@index([status])
  @@map("teachers")
}

model Student {
  id                  String               @id @default(uuid())
  userId              String?              @map("user_id")
  schoolId            String               @map("school_id")
  classId             String?              @map("class_id")
  admissionNo         String               @map("admission_no") @db.VarChar(30)
  firstName           String               @map("first_name") @db.VarChar(100)
  lastName            String               @map("last_name") @db.VarChar(100)
  dateOfBirth         DateTime?            @map("date_of_birth") @db.Date
  gender              String?              @db.VarChar(10)
  photoUrl            String?              @map("photo_url")
  address             String?
  bloodGroup          String?              @map("blood_group") @db.VarChar(5)
  emergencyContact    String?              @map("emergency_contact") @db.VarChar(200)
  status              String               @default("active") @db.VarChar(20)
  createdAt           DateTime             @default(now()) @map("created_at")
  aadhaarNo           String?              @map("aadhaar_no") @db.VarChar(12)
  middleName          String?              @map("middle_name") @db.VarChar(100)
  rollNo              String?              @map("roll_no") @db.VarChar(30)
  srNo                String?              @map("sr_no") @db.VarChar(30)
  category            String?              @db.VarChar(50)
  religion            String?              @db.VarChar(50)
  nationality         String?              @db.VarChar(50)
  motherTongue        String?              @map("mother_tongue") @db.VarChar(50)
  houseId             String?              @map("house_id") @db.VarChar(100)
  stream              String?              @db.VarChar(50)
  admissionCategory   String?              @map("admission_category") @db.VarChar(50)
  boardingType        String?              @map("boarding_type") @db.VarChar(30)
  dietType            String?              @map("diet_type") @db.VarChar(30)
  disabilityType      String?              @map("disability_type") @db.VarChar(50)
  learningSupport     String?              @map("learning_support") @db.VarChar(50)
  transportRouteId    String?              @map("transport_route_id") @db.VarChar(100)
  busStop             String?              @map("bus_stop") @db.VarChar(100)
  doctorName          String?              @map("doctor_name") @db.VarChar(100)
  doctorPhone         String?              @map("doctor_phone") @db.VarChar(20)
  insuranceProvider   String?              @map("insurance_provider") @db.VarChar(100)
  passportNo          String?              @map("passport_no") @db.VarChar(20)
  admissionChildLink  AdmissionChild?      @relation("CreatedFromAdmission")
  attendance          Attendance[]
  feeInvoices         FeeInvoice[]
  homeworkSubmissions HomeworkSubmission[]
  leaveRequests       LeaveRequest[]
  parentStudents      ParentStudent[]
  queries             StudentQuery[]
  class               Class?               @relation(fields: [classId], references: [id])
  school              School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  eventParticipants        EventParticipant[]
  examResults              ExamResult[]
  rideStudents             RideStudent[]
  sessionBookings          SessionBooking[]
  onlineClassAttendances   OnlineClassAttendance[]
  courseEnrollments        CourseEnrollment[]
  skillRatings             StudentSkillRating[]
  behaviorIncidents        BehaviorIncident[]
  reportCards              ReportCard[]
  extracurricularEntries     ExtracurricularEntry[]
  courseRecommendations      CourseRecommendation[]
  attendancePeriodSummaries  AttendancePeriodSummary[]
  cycleAcademicSummaries     CycleAcademicSummary[]
  libraryIssues              LibraryIssue[]
  hostelAllocations          HostelAllocation[]
  boardExamTrackers          BoardExamTracker[]
  subjectChatThreads         SubjectChatThread[]
  riskFlags                  RiskFlag[]
  attendanceRegularizations  AttendanceRegularization[]
  gatePasses                 GatePass[]
  feeConcessions             FeeConcession[]
  transferCertificates       TransferCertificate[]
  earlyWarningLogs           EarlyWarningLog[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([classId])
  @@index([status])
  @@map("students")
}

model Parent {
  id                String             @id @default(uuid())
  userId            String             @unique @map("user_id")
  occupation        String?
  createdAt         DateTime           @default(now()) @map("created_at")
  dateOfBirth       DateTime?          @map("date_of_birth") @db.Date
  gender            String?            @db.VarChar(10)
  aadhaarNo         String?            @map("aadhaar_no") @db.VarChar(12)
  panNo             String?            @map("pan_no") @db.VarChar(10)
  nationality       String?            @db.VarChar(50)
  annualIncome      String?            @map("annual_income") @db.VarChar(30)
  highestEducation  String?            @map("highest_education") @db.VarChar(100)
  organization      String?            @db.VarChar(100)
  alternatePhone    String?            @map("alternate_phone") @db.VarChar(20)
  parentStudents    ParentStudent[]
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  queries           StudentQuery[]
  sessionBookings   SessionBooking[]
  vendorOrders      VendorOrder[]
  consultantRatings ConsultantRating[]
  vendorRatings     VendorRating[]

  @@map("parents")
}

model ParentStudent {
  id           String   @id @default(uuid())
  parentId     String   @map("parent_id")
  studentId    String   @map("student_id")
  relationship String?  @db.VarChar(30)
  isPrimary    Boolean  @default(true) @map("is_primary")
  createdAt    DateTime @default(now()) @map("created_at")
  parent       Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([parentId, studentId])
  @@map("parent_students")
}

model Class {
  id             String         @id @default(uuid())
  schoolId       String         @map("school_id")
  name           String         @db.VarChar(50)
  grade          String         @db.VarChar(20)
  section        String         @db.VarChar(10)
  classTeacherId String?        @map("class_teacher_id")
  academicYear   String         @default("2025-2026") @map("academic_year") @db.VarChar(9)
  maxStudents    Int            @default(40) @map("max_students")
  createdAt      DateTime       @default(now()) @map("created_at")
  attendance     Attendance[]
  classTeacher   Teacher?       @relation(fields: [classTeacherId], references: [id])
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeStructures  FeeStructure[]
  homework       Homework[]
  students       Student[]
  timetables     Timetable[]
  syllabusItems  SyllabusItem[]
  exams          Exam[]
  examEntries    ExamTimetableEntry[]
  streamMasters  StreamMaster[]
  onlineClasses   OnlineClass[]
  diaryEntries    DiaryEntry[]
  yearbookEntries YearbookEntry[]

  @@unique([schoolId, grade, section, academicYear])
  @@map("classes")
}

model Attendance {
  id            String   @id @default(uuid())
  schoolId      String   @map("school_id")
  studentId     String?  @map("student_id")
  teacherId     String?  @map("teacher_id")
  classId       String?  @map("class_id")
  date          DateTime @db.Date
  status        String   @db.VarChar(10)
  markedBy      String?   @map("marked_by")
  remarks       String?
  punchInTime          DateTime? @map("punch_in_time")
  punchOutTime         DateTime? @map("punch_out_time")
  subjectAttendance    Json?     @map("subject_attendance")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  updatedBy     String?   @map("updated_by")
  class         Class?   @relation(fields: [classId], references: [id], onDelete: Cascade)
  markedByUser  User?    @relation("MarkedBy", fields: [markedBy], references: [id])
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student       Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher       Teacher? @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  updatedByUser         User?                      @relation("UpdatedBy", fields: [updatedBy], references: [id])
  regularizations       AttendanceRegularization[]

  @@unique([studentId, date])
  @@index([schoolId, date])
  @@index([classId])
  @@index([teacherId])
  @@map("attendance")
}

model FeeStructure {
  id           String       @id @default(uuid())
  schoolId     String       @map("school_id")
  classId      String?      @map("class_id")
  name         String       @db.VarChar(100)
  amount       Decimal      @db.Decimal(10, 2)
  frequency    String       @default("monthly") @db.VarChar(20)
  academicYear String       @default("2025-2026") @map("academic_year") @db.VarChar(9)
  createdAt    DateTime     @default(now()) @map("created_at")
  invoices      FeeInvoice[]
  concessions   FeeConcession[]
  lateFeeConfig LateFeeConfig[]
  class         Class?       @relation(fields: [classId], references: [id])
  school        School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("fee_structures")
}

model FeeInvoice {
  id             String        @id @default(uuid())
  schoolId       String        @map("school_id")
  studentId      String        @map("student_id")
  feeStructureId String?       @map("fee_structure_id")
  invoiceNo      String        @map("invoice_no") @db.VarChar(50)
  amount         Decimal       @db.Decimal(10, 2)
  dueDate        DateTime      @map("due_date") @db.Date
  status         String        @default("unpaid") @db.VarChar(20)
  paidAmount     Decimal       @default(0) @map("paid_amount") @db.Decimal(10, 2)
  paidAt         DateTime?     @map("paid_at")
  installmentNo  Int           @default(1) @map("installment_no")
  createdAt      DateTime      @default(now()) @map("created_at")
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  payments       FeePayment[]

  @@unique([schoolId, invoiceNo])
  @@index([schoolId])
  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@map("fee_invoices")
}

model FeePayment {
  id             String     @id @default(uuid())
  invoiceId      String     @map("invoice_id")
  amount         Decimal    @db.Decimal(10, 2)
  paymentMethod  String     @default("online") @map("payment_method") @db.VarChar(30)  // 'online' | 'cash' | 'cheque' | 'dd' | 'neft'
  transactionRef String?    @map("transaction_ref") @db.VarChar(100)
  paymentGateway String?    @map("payment_gateway") @db.VarChar(30)  // razorpay | payu | null for cash
  receiptNo      String?    @map("receipt_no") @db.VarChar(50)       // sequential receipt number
  receivedById   String?    @map("received_by_id")                   // staff who collected cash
  remarks        String?    @db.VarChar(300)
  status         String     @default("success") @db.VarChar(20)
  paidAt         DateTime   @default(now()) @map("paid_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  invoice        FeeInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("fee_payments")
}

model Homework {
  id          String               @id @default(uuid())
  schoolId    String               @map("school_id")
  classId     String               @map("class_id")
  teacherId   String               @map("teacher_id")
  subject     String               @db.VarChar(100)
  title       String               @db.VarChar(200)
  description String?
  attachments String[]
  dueDate     DateTime             @map("due_date") @db.Date
  maxMarks    Int?                 @map("max_marks")
  createdAt   DateTime             @default(now()) @map("created_at")
  class         Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  school        School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher       Teacher              @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  submissions   HomeworkSubmission[]
  timetableLogs TimetableLog[]

  @@index([schoolId])
  @@index([classId])
  @@index([teacherId])
  @@index([dueDate])
  @@map("homework")
}

model HomeworkSubmission {
  id            String   @id @default(uuid())
  homeworkId    String   @map("homework_id")
  studentId     String   @map("student_id")
  submittedAt   DateTime @default(now()) @map("submitted_at")
  marksObtained Int?     @map("marks_obtained")
  feedback      String?
  status        String   @default("submitted") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at")
  homework      Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([homeworkId, studentId])
  @@index([studentId])
  @@map("homework_submissions")
}

model Announcement {
  id             String    @id @default(uuid())
  schoolId       String    @map("school_id")
  title          String    @db.VarChar(200)
  content        String
  targetRoles    String[]  @map("target_roles")
  targetClassIds String[]  @default([]) @map("target_class_ids")
  priority       String    @default("normal") @db.VarChar(20)
  status         String    @default("active") @db.VarChar(20)
  expiresAt      DateTime? @map("expires_at")
  createdBy      String?   @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  createdByUser  User?     @relation("CreatedBy", fields: [createdBy], references: [id])
  school         School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([createdAt])
  @@map("announcements")
}

model LeaveRequest {
  id             String        @id @default(uuid())
  schoolId       String        @map("school_id")
  userId         String        @map("user_id")
  roleCode       String        @map("role_code") @db.VarChar(30)
  startDate      DateTime      @map("start_date") @db.Date
  endDate        DateTime      @map("end_date") @db.Date
  reason         String
  status         String        @default("pending") @db.VarChar(20)
  reviewedBy     String?       @map("reviewed_by")
  reviewedAt     DateTime?     @map("reviewed_at")
  createdAt      DateTime      @default(now()) @map("created_at")
  currentStep    Int           @default(0) @map("current_step")
  leaveType      String        @default("other") @map("leave_type") @db.VarChar(50)
