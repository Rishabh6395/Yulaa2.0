// ─── Timetable Log ────────────────────────────────────────────────────────────
// Tracks what topic was taught each day for a given timetable slot.
model TimetableLog {
  id         String        @id @default(uuid())
  slotId     String        @map("slot_id")
  date       DateTime      @db.Date
  topic      String?       @db.VarChar(200)
  notes      String?
  homeworkId String?       @map("homework_id")
  teacherId  String        @map("teacher_id")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @default(now()) @updatedAt @map("updated_at")
  slot       TimetableSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  homework   Homework?     @relation(fields: [homeworkId], references: [id])
  teacher    Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([slotId, date])
  @@index([slotId])
  @@index([teacherId])
  @@map("timetable_logs")
}

// ─── Timetable Reassignment ───────────────────────────────────────────────────
// Tracks when a teacher's slot is handed off to a substitute for a date range.
model TimetableReassignment {
  id                  String        @id @default(uuid())
  slotId              String        @map("slot_id")
  originalTeacherId   String        @map("original_teacher_id")
  substituteTeacherId String        @map("substitute_teacher_id")
  startDate           DateTime      @map("start_date") @db.Date
  endDate             DateTime      @map("end_date") @db.Date
  reason              String?       @db.VarChar(500)
  createdBy           String        @map("created_by")
  isActive            Boolean       @default(true) @map("is_active")
  createdAt           DateTime      @default(now()) @map("created_at")
  slot                TimetableSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)

  @@index([slotId])
  @@index([originalTeacherId])
  @@index([substituteTeacherId])
  @@index([startDate, endDate])
  @@map("timetable_reassignments")
}

// ─── Events Management ────────────────────────────────────────────────────────
model SchoolEvent {
  id           String             @id @default(uuid())
  schoolId     String             @map("school_id")
  title        String             @db.VarChar(200)
  description  String?
  eventType    String             @map("event_type") @db.VarChar(50)
  startDate    DateTime           @map("start_date")
  endDate      DateTime           @map("end_date")
  venue        String?            @db.VarChar(200)
  status       String             @default("upcoming") @db.VarChar(20)
  academicYear String             @map("academic_year") @db.VarChar(9)
  createdBy    String             @map("created_by")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @default(now()) @updatedAt @map("updated_at")
  tasks        EventTask[]
  participants EventParticipant[]
  school       School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  creator      User               @relation(fields: [createdBy], references: [id])

  @@index([schoolId])
  @@index([schoolId, academicYear])
  @@map("school_events")
}

model EventTask {
  id          String      @id @default(uuid())
  eventId     String      @map("event_id")
  title       String      @db.VarChar(200)
  description String?
  assignedTo  String?     @map("assigned_to")
  role        String?     @db.VarChar(100)
  status      String      @default("pending") @db.VarChar(20)
  dueDate     DateTime?   @map("due_date") @db.Date
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")
  event       SchoolEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  teacher     Teacher?    @relation(fields: [assignedTo], references: [id])

  @@index([eventId])
  @@map("event_tasks")
}

model EventParticipant {
  id        String      @id @default(uuid())
  eventId   String      @map("event_id")
  studentId String      @map("student_id")
  status    String      @default("registered") @db.VarChar(20)
  role      String?     @db.VarChar(100)
  attended  Boolean     @default(false)
  createdAt DateTime    @default(now()) @map("created_at")
  event     SchoolEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  student   Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([eventId, studentId])
  @@index([eventId])
  @@map("event_participants")
}

// ─── Syllabus ─────────────────────────────────────────────────────────────────
