  school       School          @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, classId, academicYear])
  @@index([schoolId])
  @@map("timetables")
}

model TimetableSlot {
  id          String         @id @default(uuid())
  timetableId String         @map("timetable_id")
  dayOfWeek   Int            @map("day_of_week")
  periodNo    Int            @map("period_no")
  startTime   String         @map("start_time") @db.VarChar(10)
  endTime     String         @map("end_time") @db.VarChar(10)
  subject     String         @db.VarChar(100)
  teacherId   String?        @map("teacher_id")
  createdAt   DateTime       @default(now()) @map("created_at")
  logs          TimetableLog[]
  reassignments TimetableReassignment[]
  teacher       Teacher?       @relation(fields: [teacherId], references: [id])
  timetable     Timetable      @relation(fields: [timetableId], references: [id], onDelete: Cascade)

  @@unique([timetableId, dayOfWeek, periodNo])
