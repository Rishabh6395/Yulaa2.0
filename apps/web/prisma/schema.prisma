  options   String[]
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, formName, fieldSlot])
  @@index([schoolId, formName])
  @@map("content_type_masters")
}

// ── Generic Workflow Engine (Attendance, Fee, Query-Parents, Query-SchoolAdmin) ──

model GenericWorkflow {
  id           String                @id @default(uuid())
  schoolId     String                @map("school_id")
  workflowType String                @map("workflow_type") @db.VarChar(50)
  // roleCode is used for workflows that are role-specific (e.g. leave)
  roleCode     String?               @map("role_code") @db.VarChar(30)
  isActive     Boolean               @default(true) @map("is_active")
  createdAt    DateTime              @default(now()) @map("created_at")
  school       School                @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  stages       GenericWorkflowStage[]

  @@unique([schoolId, workflowType, roleCode])
  @@index([schoolId])
  @@map("generic_workflows")
}

model GenericWorkflowStage {
  id             String          @id @default(uuid())
  workflowId     String          @map("workflow_id")
  stageOrder     Int             @map("stage_order")
  stageName      String          @map("stage_name") @db.VarChar(100)
  initiatorRole  String?         @map("initiator_role") @db.VarChar(30)
  approverRole   String?         @map("approver_role") @db.VarChar(30)
  approverUserId String?         @map("approver_user_id")
  spocUserId     String?         @map("spoc_user_id")
  systemTrigger  String?         @map("system_trigger") @db.VarChar(300)
  isFinal        Boolean         @default(false) @map("is_final")
  emailEnabled   Boolean         @default(false) @map("email_enabled")
  notifyEnabled  Boolean         @default(true)  @map("notify_enabled")
  notifyMessage  String?         @map("notify_message") @db.VarChar(300)
  createdAt      DateTime        @default(now()) @map("created_at")
  workflow       GenericWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, stageOrder])
  @@index([workflowId])
  @@map("generic_workflow_stages")
}

// ─── Dynamic / custom master types (school-defined) ──────────────────────────

model GenericMasterType {
  id          String               @id @default(uuid())
  schoolId    String               @map("school_id")
  name        String               @db.VarChar(100)
  slug        String               @db.VarChar(100)
  description String?              @db.VarChar(255)
  formId      String?              @db.VarChar(100) @map("form_id")
  fieldSlot   String?              @db.VarChar(100) @map("field_slot")
  isActive    Boolean              @default(true)   @map("is_active")
  createdAt   DateTime             @default(now())  @map("created_at")
  school      School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  values      GenericMasterValue[]

  @@unique([schoolId, slug])
  @@index([schoolId])
  @@map("generic_master_types")
}

model GenericMasterValue {
  id         String            @id @default(uuid())
  typeId     String            @map("type_id")
  name       String            @db.VarChar(100)
  sortOrder  Int               @default(0)    @map("sort_order")
  isActive   Boolean           @default(true) @map("is_active")
  createdAt  DateTime          @default(now()) @map("created_at")
  masterType GenericMasterType @relation(fields: [typeId], references: [id], onDelete: Cascade)

  @@unique([typeId, name])
  @@index([typeId])
  @@map("generic_master_values")
}

// ─── Career Sessions — Individual Bookings ────────────────────────────────────

model ConsultantAvailability {
  id           String           @id @default(uuid())
  consultantId String           @map("consultant_id")
  dayOfWeek    Int?             @map("day_of_week")
  date         DateTime?        @db.Date
  startTime    String           @map("start_time") @db.VarChar(10)
  endTime      String           @map("end_time") @db.VarChar(10)
  mode         String           @default("online") @db.VarChar(20)
  maxBookings  Int              @default(1) @map("max_bookings")
  isActive     Boolean          @default(true) @map("is_active")
  createdAt    DateTime         @default(now()) @map("created_at")
  consultant   Consultant       @relation(fields: [consultantId], references: [id], onDelete: Cascade)
  bookings     SessionBooking[]

  @@index([consultantId])
  @@map("consultant_availability")
}

model SessionBooking {
  id               String                  @id @default(uuid())
  consultantId     String                  @map("consultant_id")
  parentId         String                  @map("parent_id")
  availabilityId   String?                 @map("availability_id")
  studentId        String?                 @map("student_id")
  schoolId         String?                 @map("school_id")
  sessionDate      DateTime                @map("session_date") @db.Date
  startTime        String                  @map("start_time") @db.VarChar(10)
  endTime          String                  @map("end_time") @db.VarChar(10)
  mode             String                  @default("online") @db.VarChar(20)
  meetingLink      String?                 @map("meeting_link")
  notes            String?
  status           String                  @default("pending") @db.VarChar(20)
  sessionFee       Decimal?                @map("session_fee") @db.Decimal(10, 2)
  paymentStatus    String                  @default("pending") @map("payment_status") @db.VarChar(20)
  paymentRef       String?                 @map("payment_ref")
  cancellationNote String?                 @map("cancellation_note")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @default(now()) @updatedAt @map("updated_at")
  consultant       Consultant              @relation(fields: [consultantId], references: [id])
  parent           Parent                  @relation(fields: [parentId], references: [id])
  availability     ConsultantAvailability? @relation(fields: [availabilityId], references: [id])
  student          Student?                @relation(fields: [studentId], references: [id])
  school           School?                 @relation(fields: [schoolId], references: [id])
  rating           ConsultantRating?

  @@index([consultantId])
  @@index([parentId])
  @@index([sessionDate])
  @@map("session_bookings")
}

model ConsultantRating {
  id           String         @id @default(uuid())
  bookingId    String         @unique @map("booking_id")
  consultantId String         @map("consultant_id")
  parentId     String         @map("parent_id")
  rating       Int
  review       String?
  createdAt    DateTime       @default(now()) @map("created_at")
  booking      SessionBooking @relation(fields: [bookingId], references: [id])
  consultant   Consultant     @relation(fields: [consultantId], references: [id])
  parent       Parent         @relation(fields: [parentId], references: [id])

  @@index([consultantId])
  @@map("consultant_ratings")
}

// ─── Vendor E-Commerce ────────────────────────────────────────────────────────

model VendorProduct {
  id          String            @id @default(uuid())
  vendorId    String            @map("vendor_id")
  name        String            @db.VarChar(200)
  description String?
  category    String            @db.VarChar(50)
  price       Decimal           @db.Decimal(10, 2)
  mrp         Decimal?          @db.Decimal(10, 2)
  quantity    Int               @default(0)
  unit        String            @default("piece") @db.VarChar(20)
  imageUrls   String[]          @map("image_urls")
  tags        String[]
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at")
  vendor      Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  orderItems  VendorOrderItem[]

  @@index([vendorId])
  @@index([category])
  @@map("vendor_products")
}

model VendorOrder {
  id              String            @id @default(uuid())
  vendorId        String            @map("vendor_id")
  parentId        String            @map("parent_id")
  orderNo         String            @unique @map("order_no") @db.VarChar(30)
  totalAmount     Decimal           @map("total_amount") @db.Decimal(10, 2)
  deliveryAddress String?           @map("delivery_address")
  deliveryMode    String            @default("delivery") @map("delivery_mode") @db.VarChar(20)
  status          String            @default("pending") @db.VarChar(20)
  paymentStatus   String            @default("pending") @map("payment_status") @db.VarChar(20)
  paymentRef      String?           @map("payment_ref")
  notes           String?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at")
  vendor          Vendor            @relation(fields: [vendorId], references: [id])
  parent          Parent            @relation(fields: [parentId], references: [id])
  items           VendorOrderItem[]
  rating          VendorRating?

  @@index([vendorId])
  @@index([parentId])
  @@map("vendor_orders")
}

model VendorOrderItem {
  id        String        @id @default(uuid())
  orderId   String        @map("order_id")
  productId String        @map("product_id")
  quantity  Int
  unitPrice Decimal       @map("unit_price") @db.Decimal(10, 2)
  total     Decimal       @db.Decimal(10, 2)
  createdAt DateTime      @default(now()) @map("created_at")
  order     VendorOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   VendorProduct @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("vendor_order_items")
}

model VendorRating {
  id        String      @id @default(uuid())
  orderId   String      @unique @map("order_id")
  vendorId  String      @map("vendor_id")
  parentId  String      @map("parent_id")
  rating    Int
  review    String?
  createdAt DateTime    @default(now()) @map("created_at")
  order     VendorOrder @relation(fields: [orderId], references: [id])
  vendor    Vendor      @relation(fields: [vendorId], references: [id])
  parent    Parent      @relation(fields: [parentId], references: [id])

  @@index([vendorId])
  @@map("vendor_ratings")
}

// ─── Online Classes ───────────────────────────────────────────────────────────

model OnlineClass {
  id              String    @id @default(uuid())
  schoolId        String    @map("school_id")
  slotId          String?   @map("slot_id")
  teacherId       String    @map("teacher_id")
  classId         String?   @map("class_id")
  title           String    @db.VarChar(200)
  subject         String?   @db.VarChar(100)
  platform        String    @default("meet") @db.VarChar(20)
  meetingLink     String?   @map("meeting_link")
  meetingId       String?   @map("meeting_id") @db.VarChar(300)
  meetingPassword String?   @map("meeting_password") @db.VarChar(100)
  scheduledAt     DateTime  @map("scheduled_at")
  durationMinutes Int       @default(45) @map("duration_minutes")
  status          String    @default("scheduled") @db.VarChar(20)
  recordingUrl    String?   @map("recording_url")
  isRecorded      Boolean   @default(false) @map("is_recorded")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")
  school              School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher             Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  slot                TimetableSlot? @relation(fields: [slotId], references: [id])
  class               Class?    @relation(fields: [classId], references: [id])
  attendances         OnlineClassAttendance[]
  courseRecommendations CourseRecommendation[]

  @@index([schoolId, scheduledAt])
  @@index([teacherId])
  @@index([classId])
  @@map("online_classes")
}

model OnlineClassAttendance {
  id              String      @id @default(uuid())
  onlineClassId   String      @map("online_class_id")
  studentId       String      @map("student_id")
  status          String      @default("absent") @db.VarChar(20)
  markedByTeacher Boolean     @default(false) @map("marked_by_teacher")
  joinedAt        DateTime?   @map("joined_at")
  leftAt          DateTime?   @map("left_at")
  durationMinutes Int?        @map("duration_minutes")
  createdAt       DateTime    @default(now()) @map("created_at")
  onlineClass     OnlineClass @relation(fields: [onlineClassId], references: [id], onDelete: Cascade)
  student         Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([onlineClassId, studentId])
  @@index([onlineClassId])
  @@index([studentId])
  @@map("online_class_attendance")
}

// ─── Courses ──────────────────────────────────────────────────────────────────

model Course {
  id                  String    @id @default(uuid())
  schoolId            String?   @map("school_id")
  teacherId           String?   @map("teacher_id")
  instructorName      String?   @map("instructor_name") @db.VarChar(200)
  title               String    @db.VarChar(200)
  description         String?
  thumbnail           String?   @db.VarChar(500)
  type                String    @default("recorded") @db.VarChar(20)
  price               Decimal   @default(0) @db.Decimal(10, 2)
  currency            String    @default("INR") @db.VarChar(5)
  isFree              Boolean   @default(false) @map("is_free")
  isPublished         Boolean   @default(false) @map("is_published")
  isExternal          Boolean   @default(false) @map("is_external")
  requiresApproval    Boolean   @default(false) @map("requires_approval")
  approvedById        String?   @map("approved_by_id")
  approvedAt          DateTime? @map("approved_at")
  totalDuration       Int       @default(0) @map("total_duration")
  certificateEnabled  Boolean   @default(false) @map("certificate_enabled")
  tags                String[]
  targetGrades        String[]  @map("target_grades")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @default(now()) @updatedAt @map("updated_at")
  school                School?   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher               Teacher?  @relation(fields: [teacherId], references: [id])
  modules               CourseModule[]
  enrollments           CourseEnrollment[]
  courseRecommendations CourseRecommendation[]

  @@index([schoolId, isPublished])
  @@index([isExternal, isPublished])
  @@map("courses")
}

model CourseModule {
  id          String         @id @default(uuid())
  courseId    String         @map("course_id")
  title       String         @db.VarChar(200)
  description String?
  sortOrder   Int            @default(0) @map("sort_order")
  createdAt   DateTime       @default(now()) @map("created_at")
  course      Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons     CourseLesson[]

  @@index([courseId])
  @@map("course_modules")
}

model CourseLesson {
  id          String           @id @default(uuid())
  moduleId    String           @map("module_id")
  title       String           @db.VarChar(200)
  description String?
  type        String           @default("video") @db.VarChar(20)
  contentUrl  String?          @map("content_url")
  meetingLink String?          @map("meeting_link")
  scheduledAt DateTime?        @map("scheduled_at")
  duration    Int?
  isPreview   Boolean          @default(false) @map("is_preview")
  sortOrder   Int              @default(0) @map("sort_order")
  createdAt   DateTime         @default(now()) @map("created_at")
  module      CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress    CourseProgress[]

  @@index([moduleId])
  @@map("course_lessons")
}

model CourseEnrollment {
  id                  String          @id @default(uuid())
  courseId            String          @map("course_id")
  userId              String          @map("user_id")
  studentId           String?         @map("student_id")
  enrolledAt          DateTime        @default(now()) @map("enrolled_at")
  completedAt         DateTime?       @map("completed_at")
  progressPct         Float           @default(0) @map("progress_pct")
  certificateNo       String?         @unique @map("certificate_no") @db.VarChar(50)
  certificateUrl      String?         @map("certificate_url")
  certificateIssuedAt DateTime?       @map("certificate_issued_at")
  paymentStatus       String          @default("pending") @map("payment_status") @db.VarChar(20)
  paymentRef          String?         @map("payment_ref")
  amountPaid          Decimal         @default(0) @map("amount_paid") @db.Decimal(10, 2)
  gateway             String?         @db.VarChar(20)
  createdAt           DateTime        @default(now()) @map("created_at")
  course              Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  student             Student?        @relation(fields: [studentId], references: [id])
  progress            CourseProgress[]

  @@unique([courseId, userId])
  @@index([courseId])
  @@index([userId])
  @@map("course_enrollments")
}

model CourseProgress {
  id             String           @id @default(uuid())
  enrollmentId   String           @map("enrollment_id")
  lessonId       String           @map("lesson_id")
  completedAt    DateTime?        @map("completed_at")
  watchedSeconds Int              @default(0) @map("watched_seconds")
  enrollment     CourseEnrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  lesson         CourseLesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([enrollmentId, lessonId])
  @@index([enrollmentId])
  @@map("course_progress")
}

// ─── Student Skill Ratings ────────────────────────────────────────────────────
model StudentSkillRating {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  studentId    String   @map("student_id")
  teacherId    String   @map("teacher_id")
  cycleId      String?  @map("cycle_id")
  skillName    String   @map("skill_name") @db.VarChar(100)
  rating       Int
  comments     String?  @db.VarChar(500)
  academicYear String   @map("academic_year") @db.VarChar(9)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  school  School            @relation(fields: [schoolId],  references: [id], onDelete: Cascade)
  student Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher Teacher           @relation(fields: [teacherId], references: [id])
  cycle   PerformanceCycle? @relation(fields: [cycleId], references: [id])

  @@unique([schoolId, studentId, teacherId, skillName, academicYear])
  @@index([schoolId, studentId])
  @@index([cycleId])
  @@map("student_skill_ratings")
}

// ─── Behavior Incidents ───────────────────────────────────────────────────────
model BehaviorIncident {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  studentId    String   @map("student_id")
  cycleId      String?  @map("cycle_id")
  reportedBy   String   @map("reported_by")
  incidentType String   @map("incident_type") @db.VarChar(20)
  category     String   @db.VarChar(100)
  description  String
  severity     String?  @db.VarChar(20)
  weight       Int      @default(1)
  actionTaken  String?  @map("action_taken")
  date         DateTime @db.Date
  createdAt    DateTime @default(now()) @map("created_at")

  school  School            @relation(fields: [schoolId],  references: [id], onDelete: Cascade)
  student Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cycle   PerformanceCycle? @relation(fields: [cycleId], references: [id])

  @@index([schoolId, studentId])
  @@index([schoolId, date])
  @@index([cycleId])
  @@map("behavior_incidents")
}

// ─── Performance Cycles ───────────────────────────────────────────────────────
// Configurable by super_admin per school. Drives exam, report card, behavior, ECO tagging.
model PerformanceCycle {
  id                   String    @id @default(uuid())
  schoolId             String    @map("school_id")
  name                 String    @db.VarChar(100)
  cycleType            String    @map("cycle_type") @db.VarChar(20)  // 'monthly' | 'quarterly' | 'half_yearly' | 'yearly' | 'custom'
  academicYear         String    @map("academic_year") @db.VarChar(9)
  startDate            DateTime  @map("start_date") @db.Date
  endDate              DateTime  @map("end_date") @db.Date
  status               String    @default("upcoming") @db.VarChar(20)  // 'upcoming' | 'active' | 'locked' | 'report_published'
  isActive             Boolean   @default(false) @map("is_active")
  reportCardTemplate   String?   @map("report_card_template") @db.VarChar(50)  // 'compact' | 'standard' | 'comprehensive'
  lockedAt             DateTime? @map("locked_at")
  reportPublishedAt    DateTime? @map("report_published_at")
  createdById          String    @map("created_by_id")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at")

  school                  School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  exams                   Exam[]
  reportCards             ReportCard[]
  behaviorIncidents       BehaviorIncident[]
  skillRatings            StudentSkillRating[]
  extracurricularEntries  ExtracurricularEntry[]
  attendanceSummaries     AttendancePeriodSummary[]
  academicSummaries       CycleAcademicSummary[]

  @@index([schoolId, academicYear])
  @@index([schoolId, status])
  @@map("performance_cycles")
}

// ─── School Timing Config ─────────────────────────────────────────────────────
// Attendance module advance config: defines school hours for late-marking.
model SchoolTimingConfig {
  id              String   @id @default(uuid())
  schoolId        String   @map("school_id")
  dayOfWeek       Int      @map("day_of_week")  // 0=Sunday … 6=Saturday; -1 = all weekdays
  schoolStartTime String   @map("school_start_time") @db.VarChar(5)  // "HH:MM"
  schoolEndTime   String   @map("school_end_time")   @db.VarChar(5)
  lateAfterMins   Int      @default(15) @map("late_after_mins")  // minutes past start = late
  halfDayAfterMins Int     @default(180) @map("half_day_after_mins")
  isHoliday       Boolean  @default(false) @map("is_holiday")
  effectiveFrom   DateTime @map("effective_from") @db.Date
  createdById     String   @map("created_by_id")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, dayOfWeek, effectiveFrom])
  @@index([schoolId])
  @@map("school_timing_configs")
}

// ─── Extracurricular Entries ──────────────────────────────────────────────────
// Tracks student participation in sports, cultural events, clubs, etc.
model ExtracurricularEntry {
  id           String    @id @default(uuid())
  schoolId     String    @map("school_id")
  studentId    String    @map("student_id")
  cycleId      String?   @map("cycle_id")
  academicYear String    @map("academic_year") @db.VarChar(9)
  category     String    @db.VarChar(50)
  activity     String    @db.VarChar(200)
  role         String?   @db.VarChar(100)
  achievement  String?   @db.VarChar(200)
  level        String?   @db.VarChar(30)
  points       Int       @default(1)
  date         DateTime  @db.Date
  recordedById String    @map("recorded_by_id")
  approvedById String?   @map("approved_by_id")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  school  School            @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cycle   PerformanceCycle? @relation(fields: [cycleId], references: [id])

  @@index([schoolId, studentId])
  @@index([schoolId, academicYear])
  @@index([cycleId])
  @@map("extracurricular_entries")
}

// ─── Course Recommendations ───────────────────────────────────────────────────
// Auto-generated or manual links from weak subjects → OnlineClass/Course.
model CourseRecommendation {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  studentId    String   @map("student_id")
  cycleId      String?  @map("cycle_id")
  subject      String   @db.VarChar(100)
  reason       String?  @db.VarChar(200)  // e.g. "Below average for 2 consecutive cycles"
  courseId     String?  @map("course_id")
  onlineClassId String? @map("online_class_id")
  source       String   @default("auto") @db.VarChar(20)  // 'auto' | 'manual'
  status       String   @default("pending") @db.VarChar(20)  // 'pending' | 'accepted' | 'dismissed'
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  school      School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course?       @relation(fields: [courseId], references: [id])
  onlineClass OnlineClass?  @relation(fields: [onlineClassId], references: [id])

  @@index([schoolId, studentId])
  @@index([cycleId])
  @@map("course_recommendations")
}

// ─── Academic Year Master ─────────────────────────────────────────────────────
// Configured by super_admin; each school uses one active academic year.
model AcademicYear {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  label       String   @db.VarChar(9)   // e.g. "2025-2026"
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime @map("end_date")   @db.Date
  isActive    Boolean  @default(false) @map("is_active")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, label])
  @@index([schoolId, isActive])
  @@map("academic_years")
}

// ─── Behavior KPI Config ──────────────────────────────────────────────────────
// Catalog of incident types with weights — configured per school by super_admin.
model BehaviorKpiConfig {
  id            String   @id @default(uuid())
  schoolId      String   @map("school_id")
  incidentType  String   @map("incident_type") @db.VarChar(20)   // 'positive' | 'negative'
  code          String   @db.VarChar(60)
  label         String   @db.VarChar(100)
  weight        Int                        // positive = +N, negative = -N
  severity      String?  @db.VarChar(20)  // null | 'low' | 'medium' | 'high'
  isActive      Boolean  @default(true) @map("is_active")
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, code])
  @@index([schoolId, incidentType])
  @@map("behavior_kpi_configs")
}

// ─── ECO Points Matrix ────────────────────────────────────────────────────────
// Level × achievement points grid configured by super_admin per school.
model EcoPointsMatrix {
  id          String   @id @default(uuid())
  schoolId    String   @map("school_id")
  level       String   @db.VarChar(30)       // 'school' | 'district' | 'state' | 'national' | 'international'
  achievement String   @db.VarChar(50)       // 'participant' | 'runner_up' | 'winner' | 'special_mention'
  points      Int
  createdById String   @map("created_by_id")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, level, achievement])
  @@index([schoolId])
  @@map("eco_points_matrix")
}

// ─── Attendance Period Summary ────────────────────────────────────────────────
// Cached cycle-based attendance aggregation per student.
model AttendancePeriodSummary {
  id                String   @id @default(uuid())
  schoolId          String   @map("school_id")
  studentId         String   @map("student_id")
  cycleId           String   @map("cycle_id")
  workingDays       Int      @default(0) @map("working_days")
  presentDays       Int      @default(0) @map("present_days")
  absentDays        Int      @default(0) @map("absent_days")
  lateDays          Int      @default(0) @map("late_days")
  halfDays          Int      @default(0) @map("half_days")
  excusedDays       Int      @default(0) @map("excused_days")
  attendancePercent Decimal  @default(0) @map("attendance_percent") @db.Decimal(5, 2)
  lateCount         Int      @default(0) @map("late_count")
  rating            String?  @db.VarChar(30)
  computedAt        DateTime @default(now()) @map("computed_at")

  school  School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cycle   PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([studentId, cycleId])
  @@index([schoolId, cycleId])
  @@map("attendance_period_summaries")
}

// ─── Cycle Academic Summary ───────────────────────────────────────────────────
// Per-student per-subject per-cycle academic snapshot.
model CycleAcademicSummary {
  id                String   @id @default(uuid())
  schoolId          String   @map("school_id")
  studentId         String   @map("student_id")
  cycleId           String   @map("cycle_id")
  classId           String?  @map("class_id")
  subjectsData      String   @map("subjects_data") @db.Text  // JSON: [{subject, maxMarks, marks, pct, grade, classRank}]
  overallPercentage Decimal  @default(0) @map("overall_percentage") @db.Decimal(5, 2)
  overallGrade      String?  @map("overall_grade") @db.VarChar(5)
  classRank         Int?     @map("class_rank")
  gradeRank         Int?     @map("grade_rank")
  classAverage      Decimal? @map("class_average") @db.Decimal(5, 2)
  weakSubjects      String?  @map("weak_subjects") @db.VarChar(500)  // CSV of subjects needing attention
  strongSubjects    String?  @map("strong_subjects") @db.VarChar(500)
  rating            String?  @db.VarChar(30)
  bellCurveData     String?  @map("bell_curve_data") @db.Text  // JSON: per-subject distribution
  computedAt        DateTime @default(now()) @map("computed_at")

  school  School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  cycle   PerformanceCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  @@unique([studentId, cycleId])
  @@index([schoolId, cycleId])
  @@map("cycle_academic_summaries")
}

// ─── Attendance Regularization ────────────────────────────────────────────────
// Teacher requests correction, principal/HOD approves with audit trail.
model AttendanceRegularization {
  id            String    @id @default(uuid())
  schoolId      String    @map("school_id")
  studentId     String    @map("student_id")
  attendanceId  String    @map("attendance_id")
  requestedById String    @map("requested_by_id")
  fromStatus    String    @map("from_status") @db.VarChar(20)  // original status
  toStatus      String    @map("to_status")   @db.VarChar(20)  // requested status
  reason        String    @db.VarChar(500)
  status        String    @default("pending") @db.VarChar(20)  // 'pending' | 'approved' | 'rejected'
  reviewedById  String?   @map("reviewed_by_id")
  reviewedAt    DateTime? @map("reviewed_at")
  reviewComment String?   @map("review_comment") @db.VarChar(300)
  createdAt     DateTime  @default(now()) @map("created_at")

  school      School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attendance  Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)

  @@index([schoolId, status])
  @@index([studentId])
  @@map("attendance_regularizations")
}

// ─── Gate Pass ────────────────────────────────────────────────────────────────
// Student early leaving with teacher permission and parent OTP.
model GatePass {
  id              String    @id @default(uuid())
  schoolId        String    @map("school_id")
  studentId       String    @map("student_id")
  issuedById      String    @map("issued_by_id")
  exitTime        DateTime  @map("exit_time")
  expectedReturn  DateTime? @map("expected_return")
  reason          String    @db.VarChar(300)
  parentConsent   Boolean   @default(false) @map("parent_consent")
  parentOtp       String?   @map("parent_otp") @db.VarChar(6)  // stored hashed
  otpVerifiedAt   DateTime? @map("otp_verified_at")
  returnedAt      DateTime? @map("returned_at")
  status          String    @default("issued") @db.VarChar(20)  // 'issued' | 'returned' | 'not_returned'
  createdAt       DateTime  @default(now()) @map("created_at")

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId])
  @@index([schoolId, exitTime])
  @@map("gate_passes")
}

// ─── Fee Concession ───────────────────────────────────────────────────────────
// Discounts/scholarships applied per student per fee structure.
model FeeConcession {
  id              String     @id @default(uuid())
  schoolId        String     @map("school_id")
  studentId       String     @map("student_id")
  feeStructureId  String?    @map("fee_structure_id")
  concessionType  String     @map("concession_type") @db.VarChar(50)  // 'rte' | 'merit' | 'staff_ward' | 'sibling' | 'scholarship' | 'custom'
  discountPercent Decimal?   @map("discount_percent") @db.Decimal(5, 2)
  discountAmount  Decimal?   @map("discount_amount")  @db.Decimal(10, 2)  // fixed override
  reason          String?    @db.VarChar(300)
  academicYear    String     @map("academic_year") @db.VarChar(9)
  status          String     @default("pending") @db.VarChar(20)  // 'pending' | 'approved' | 'rejected'
  approvedById    String?    @map("approved_by_id")
  approvedAt      DateTime?  @map("approved_at")
  validFrom       DateTime?  @map("valid_from") @db.Date
  validTo         DateTime?  @map("valid_to")   @db.Date
  isActive        Boolean    @default(true) @map("is_active")
  createdById     String     @map("created_by_id")
  createdAt       DateTime   @default(now()) @map("created_at")

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id])

  @@index([schoolId, studentId])
  @@index([schoolId, academicYear])
  @@map("fee_concessions")
}

// ─── Late Fee Config ──────────────────────────────────────────────────────────
// Per-school late fee rules: auto-add after due date + grace period.
model LateFeeConfig {
  id              String   @id @default(uuid())
  schoolId        String   @map("school_id")
  feeCategory     String   @default("default") @map("fee_category") @db.VarChar(50)  // fee category slug or 'default'
  academicYear    String   @default("all") @map("academic_year") @db.VarChar(9)      // specific year or 'all'
  feeStructureId  String?  @map("fee_structure_id")  // null = applies to all
  graceDays       Int      @default(0) @map("grace_days")
  lateFeeType     String   @default("fixed") @map("late_fee_type") @db.VarChar(10)  // 'fixed' | 'percent'
  lateFeeValue    Decimal  @map("late_fee_value") @db.Decimal(10, 2)
  maxLateFee      Decimal? @map("max_late_fee") @db.Decimal(10, 2)
  isActive        Boolean  @default(true) @map("is_active")
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  school       School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure? @relation(fields: [feeStructureId], references: [id])

  @@unique([schoolId, feeCategory, academicYear])
  @@index([schoolId])
  @@map("late_fee_configs")
}

// ─── Transfer Certificate ─────────────────────────────────────────────────────
// Generated when student leaves. Requires principal approval workflow.
model TransferCertificate {
  id                String    @id @default(uuid())
  schoolId          String    @map("school_id")
  studentId         String?   @map("student_id")         // null if student not yet created
  applicationId     String?   @unique @map("application_id")  // linked from admission for TC on joining
  tcNumber          String    @map("tc_number") @db.VarChar(30)
  issueDate         DateTime? @map("issue_date") @db.Date
  dateOfLeaving     DateTime? @map("date_of_leaving") @db.Date
  lastClassAttended String?   @map("last_class_attended") @db.VarChar(50)
  reasonForLeaving  String?   @map("reason_for_leaving") @db.VarChar(200)
  duesClearedStatus Boolean   @default(false) @map("dues_cleared_status")
  conductCertificate String?  @map("conduct_certificate") @db.VarChar(50)  // 'good' | 'satisfactory' | 'not_satisfactory'
  status            String    @default("draft") @db.VarChar(20)  // 'draft' | 'pending_approval' | 'approved' | 'issued'
  requestedById     String    @map("requested_by_id")
  approvedById      String?   @map("approved_by_id")
  approvedAt        DateTime? @map("approved_at")
  remarks           String?   @db.VarChar(500)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  school      School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student     Student?             @relation(fields: [studentId], references: [id])
  application AdmissionApplication? @relation(fields: [applicationId], references: [id])

  @@unique([schoolId, tcNumber])
  @@index([schoolId, status])
  @@index([studentId])
  @@map("transfer_certificates")
}

// ─── Early Warning Log ────────────────────────────────────────────────────────
// Auto-triggered when student drops 2 consecutive cycles.
model EarlyWarningLog {
  id           String   @id @default(uuid())
  schoolId     String   @map("school_id")
  studentId    String   @map("student_id")
  cycleId      String   @map("cycle_id")
  warningType  String   @map("warning_type") @db.VarChar(30)  // 'attendance_drop' | 'academic_drop' | 'composite_drop'
  segment      String?  @db.VarChar(20)  // 'academic' | 'attendance' | 'behavior' | 'eco'
  subject      String?  @db.VarChar(100) // for academic drops
  previousRating String? @map("previous_rating") @db.VarChar(30)
  currentRating  String? @map("current_rating")  @db.VarChar(30)
  notifiedTeacherId String? @map("notified_teacher_id")
  notifiedParent    Boolean @default(false) @map("notified_parent")
  resolvedAt   DateTime? @map("resolved_at")
  createdAt    DateTime @default(now()) @map("created_at")

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, studentId])
  @@index([cycleId])
  @@map("early_warning_logs")
}

// ─── Library ──────────────────────────────────────────────────────────────────

model LibraryBook {
  id              String   @id @default(uuid())
  schoolId        String   @map("school_id")
  isbn            String?  @db.VarChar(20)
  title           String   @db.VarChar(300)
  author          String?  @db.VarChar(200)
  publisher       String?  @db.VarChar(200)
  genre           String?  @db.VarChar(50)
  subject         String?  @db.VarChar(100)
  language        String   @default("English") @db.VarChar(30)
  totalCopies     Int      @default(1) @map("total_copies")
  availableCopies Int      @default(1) @map("available_copies")
  location        String?  @db.VarChar(100)  // shelf/rack
  coverUrl        String?  @map("cover_url")
  isActive        Boolean  @default(true) @map("is_active")
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  school  School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  issues  LibraryIssue[]

  @@unique([schoolId, isbn])
  @@index([schoolId, subject])
  @@map("library_books")
}

model LibraryIssue {
  id          String    @id @default(uuid())
  schoolId    String    @map("school_id")
  bookId      String    @map("book_id")
  studentId   String?   @map("student_id")
  teacherId   String?   @map("teacher_id")
  issueDate   DateTime  @map("issue_date") @db.Date
  dueDate     DateTime  @map("due_date")   @db.Date
  returnDate  DateTime? @map("return_date") @db.Date
  fine        Decimal?  @db.Decimal(8, 2)
  status      String    @default("issued") @db.VarChar(20)  // 'issued' | 'returned' | 'overdue' | 'lost'
  issuedById  String    @map("issued_by_id")
  remarks     String?   @db.VarChar(300)
  createdAt   DateTime  @default(now()) @map("created_at")

  school    School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  book      LibraryBook  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  student   Student?     @relation(fields: [studentId], references: [id])
  teacher   Teacher?     @relation(fields: [teacherId], references: [id])

  @@index([schoolId, status])
  @@index([bookId])
  @@index([studentId])
  @@map("library_issues")
}

// ─── Hostel / Boarding ────────────────────────────────────────────────────────

model HostelBlock {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  name      String   @db.VarChar(100)
  gender    String   @db.VarChar(10)   // 'boys' | 'girls' | 'mixed'
  wardenId  String?  @map("warden_id")
  capacity  Int      @default(0)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  school School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  rooms  HostelRoom[]

  @@index([schoolId])
  @@map("hostel_blocks")
}

model HostelRoom {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  blockId   String   @map("block_id")
  roomNo    String   @map("room_no") @db.VarChar(20)
  roomType  String   @default("shared") @map("room_type") @db.VarChar(20)  // 'single' | 'double' | 'shared'
  capacity  Int      @default(4)
  floor     Int?
  amenities String?  @db.VarChar(300)  // CSV: wifi, ac, attached_bath
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  block       HostelBlock        @relation(fields: [blockId], references: [id], onDelete: Cascade)
  allocations HostelAllocation[]

  @@unique([blockId, roomNo])
  @@index([schoolId])
  @@map("hostel_rooms")
}

model HostelAllocation {
  id           String    @id @default(uuid())
  schoolId     String    @map("school_id")
  studentId    String    @map("student_id")
  roomId       String    @map("room_id")
  bedNo        String?   @map("bed_no") @db.VarChar(10)
  academicYear String    @map("academic_year") @db.VarChar(9)
  joinDate     DateTime  @map("join_date") @db.Date
  leaveDate    DateTime? @map("leave_date") @db.Date
  mealPlan     String?   @map("meal_plan") @db.VarChar(20)  // 'veg' | 'non_veg' | 'jain'
  status       String    @default("active") @db.VarChar(20)  // 'active' | 'vacated' | 'transferred'
  createdById  String    @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")

  school  School     @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  room    HostelRoom @relation(fields: [roomId], references: [id])

  @@unique([studentId, academicYear])
  @@index([schoolId, roomId])
  @@map("hostel_allocations")
}

// ─── School Diary / Circular ──────────────────────────────────────────────────

model DiaryEntry {
  id              String   @id @default(uuid())
  schoolId        String   @map("school_id")
  classId         String   @map("class_id")
  teacherId       String   @map("teacher_id")
  date            DateTime @db.Date
  subject         String?  @db.VarChar(100)
  content         String   @db.Text
  homeworkDetails String?  @map("homework_details") @db.Text
  attachments     Json?    // [{url, name, type}]
  isPublished     Boolean  @default(true) @map("is_published")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@index([schoolId, classId, date])
  @@index([teacherId])
  @@map("diary_entries")
}

// ─── Staff HRMS ───────────────────────────────────────────────────────────────

model StaffSalaryConfig {
  id               String   @id @default(uuid())
  schoolId         String   @map("school_id")
  teacherId        String   @unique @map("teacher_id")
  basic            Decimal  @db.Decimal(10, 2)
  hra              Decimal  @default(0) @db.Decimal(10, 2)
  da               Decimal  @default(0) @db.Decimal(10, 2)
  ta               Decimal  @default(0) @db.Decimal(10, 2)
  otherAllowances  Decimal  @default(0) @map("other_allowances") @db.Decimal(10, 2)
  pfPercent        Decimal  @default(12) @map("pf_percent") @db.Decimal(5, 2)   // employee PF %
  pfEmployer       Decimal  @default(12) @map("pf_employer") @db.Decimal(5, 2)
  esiPercent       Decimal  @default(0.75) @map("esi_percent") @db.Decimal(5, 2)
  esiEmployer      Decimal  @default(3.25) @map("esi_employer") @db.Decimal(5, 2)
  tdsMonthly       Decimal  @default(0) @map("tds_monthly") @db.Decimal(10, 2)
  effectiveFrom    DateTime @map("effective_from") @db.Date
  createdById      String   @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  school   School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher  Teacher       @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  payrolls StaffPayroll[]

  @@index([schoolId])
  @@map("staff_salary_configs")
}

model StaffPayroll {
  id              String    @id @default(uuid())
  schoolId        String    @map("school_id")
  teacherId       String    @map("teacher_id")
  configId        String?   @map("config_id")
  month           Int       // 1–12
  year            Int
  workingDays     Int       @default(0) @map("working_days")
  presentDays     Int       @default(0) @map("present_days")
  leaveDays       Int       @default(0) @map("leave_days")
  lopDays         Decimal   @default(0) @map("lop_days") @db.Decimal(4, 1)  // loss-of-pay
  basic           Decimal   @db.Decimal(10, 2)
  hra             Decimal   @default(0) @db.Decimal(10, 2)
  da              Decimal   @default(0) @db.Decimal(10, 2)
  ta              Decimal   @default(0) @db.Decimal(10, 2)
  otherAllowances Decimal   @default(0) @map("other_allowances") @db.Decimal(10, 2)
  grossSalary     Decimal   @map("gross_salary") @db.Decimal(10, 2)
  pfEmployee      Decimal   @default(0) @map("pf_employee") @db.Decimal(10, 2)
  pfEmployer      Decimal   @default(0) @map("pf_employer") @db.Decimal(10, 2)
  esiEmployee     Decimal   @default(0) @map("esi_employee") @db.Decimal(10, 2)
  esiEmployer     Decimal   @default(0) @map("esi_employer") @db.Decimal(10, 2)
  tds             Decimal   @default(0) @db.Decimal(10, 2)
  otherDeductions Decimal   @default(0) @map("other_deductions") @db.Decimal(10, 2)
  netSalary       Decimal   @map("net_salary") @db.Decimal(10, 2)
  status          String    @default("draft") @db.VarChar(20)  // 'draft' | 'approved' | 'paid'
  paidAt          DateTime? @map("paid_at")
  paidById        String?   @map("paid_by_id")
  payslipUrl      String?   @map("payslip_url")
  remarks         String?   @db.VarChar(300)
  createdById     String    @map("created_by_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  school  School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacher Teacher            @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  config  StaffSalaryConfig? @relation(fields: [configId], references: [id])

  @@unique([teacherId, month, year])
  @@index([schoolId, month, year])
  @@map("staff_payrolls")
}

// ─── Board Exam Tracker ───────────────────────────────────────────────────────

model BoardExamTracker {
  id                String    @id @default(uuid())
  schoolId          String    @map("school_id")
  studentId         String    @map("student_id")
  classId           String?   @map("class_id")
  subject           String    @db.VarChar(100)
  boardExamType     String    @map("board_exam_type") @db.VarChar(20)  // 'class10' | 'class12' | 'entrance'
  examDate          DateTime? @map("exam_date") @db.Date
  syllabusCoverage  Int       @default(0) @map("syllabus_coverage")   // 0–100 %
  practiceTestScore Decimal?  @map("practice_test_score") @db.Decimal(5, 2)
  targetScore       Decimal?  @map("target_score") @db.Decimal(5, 2)
  weakTopics        String?   @map("weak_topics") @db.Text   // JSON array
  strongTopics      String?   @map("strong_topics") @db.Text
  notes             String?   @db.Text
  updatedById       String    @map("updated_by_id")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @default(now()) @updatedAt @map("updated_at")

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, subject, boardExamType])
  @@index([schoolId, boardExamType])
  @@map("board_exam_trackers")
}

// ─── Subject Chat (Parent-Teacher on weak subjects) ───────────────────────────

model SubjectChatThread {
  id        String   @id @default(uuid())
  schoolId  String   @map("school_id")
  studentId String   @map("student_id")
  teacherId String   @map("teacher_id")
  subject   String   @db.VarChar(100)
  cycleId   String?  @map("cycle_id")
  status    String   @default("open") @db.VarChar(20)  // 'open' | 'resolved'
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  school   School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student  Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher  Teacher              @relation(fields: [teacherId], references: [id])
  messages SubjectChatMessage[]

  @@unique([studentId, teacherId, subject, cycleId])
  @@index([schoolId])
  @@map("subject_chat_threads")
}

model SubjectChatMessage {
  id          String    @id @default(uuid())
  threadId    String    @map("thread_id")
  senderId    String    @map("sender_id")
  senderRole  String    @map("sender_role") @db.VarChar(20)  // 'teacher' | 'parent' | 'student'
  message     String    @db.Text
  attachments Json?
  readAt      DateTime? @map("read_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  thread SubjectChatThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("subject_chat_messages")
}

// ─── Risk Flag (Predictive Risk Scoring) ─────────────────────────────────────

model RiskFlag {
  id              String    @id @default(uuid())
  schoolId        String    @map("school_id")
  studentId       String    @map("student_id")
  riskLevel       String    @map("risk_level") @db.VarChar(20)  // 'low' | 'medium' | 'high' | 'critical'
  riskScore       Int       @map("risk_score")  // 0–100
  triggers        Json      // [{type, detail}] — e.g. [{type:'attendance', detail:'68%'}]
  attendancePct   Decimal?  @map("attendance_pct") @db.Decimal(5, 2)
  decliningExams  Int       @default(0) @map("declining_exams")
  behaviorScore   Int?      @map("behavior_score")
  recommendedAction String? @map("recommended_action") @db.VarChar(300)
  resolvedAt      DateTime? @map("resolved_at")
  resolvedById    String?   @map("resolved_by_id")
  computedAt      DateTime  @default(now()) @map("computed_at")

  school  School  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([schoolId, riskLevel])
  @@index([studentId])
  @@map("risk_flags")
}

// ─── Grading Scheme (Super Admin configures per school) ───────────────────────

model GradingScheme {
  id        String  @id @default(uuid())
  schoolId  String  @map("school_id")
  gradeLevel String @default("all") @map("grade_level") @db.VarChar(10)  // '1'–'12', 'KG', 'all'
  label     String  @db.VarChar(10)   // 'A+', 'A', 'B+', 'B', 'C', 'D', 'F'
  minPct    Int     @map("min_pct")   // lower bound (inclusive)
  maxPct    Int     @map("max_pct")   // upper bound (inclusive, 100 for top band)
  gpaPoints Decimal @default(0) @map("gpa_points") @db.Decimal(4, 2)
  remark    String? @db.VarChar(100)  // "Outstanding", "Excellent", "Good"
  createdById String @map("created_by_id")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, gradeLevel, label])
  @@index([schoolId])
  @@map("grading_schemes")
}

// ─── Subject Catalog (Super Admin defines subjects per grade per school) ──────

model SubjectCatalog {
  id        String  @id @default(uuid())
  schoolId  String  @map("school_id")
  gradeLevel String @default("all") @map("grade_level") @db.VarChar(10)  // '1'–'12', 'KG', 'all'
  subject   String  @db.VarChar(100)
  code      String? @db.VarChar(20)   // Subject code e.g. 'MATH10'
  isCore    Boolean @default(true) @map("is_core")
  maxMarks  Int     @default(100) @map("max_marks")
  passMarks Int     @default(33) @map("pass_marks")
  createdById String @map("created_by_id")

  school School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([schoolId, gradeLevel, subject])
  @@index([schoolId, gradeLevel])
  @@map("subject_catalogs")
}

// ─── Performance Template (Super Admin defines cycle templates for schools) ───

model PerformanceTemplate {
  id              String   @id @default(uuid())
  name            String   @db.VarChar(100)   // "Quarterly Assessment", "Monthly Check-in"
  description     String?  @db.Text
  cycleType       String   @db.VarChar(20)    // 'monthly' | 'quarterly' | 'half_yearly' | 'yearly'
  isActive        Boolean  @default(true) @map("is_active")
  // Default weights (can be overridden per school)
  weightAcademic  Int      @default(40) @map("weight_academic")
  weightAttendance Int     @default(30) @map("weight_attendance")
  weightBehavior  Int      @default(20) @map("weight_behavior")
  weightEco       Int      @default(10) @map("weight_eco")
  reportCardTemplate String @default("standard") @map("report_card_template") @db.VarChar(30)
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")

  @@map("performance_templates")
}
