# ──────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, local, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/yulaa?sslmode=require

# ──────────────────────────────────────────────────────────────
# Auth
# ──────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "require('crypto').randomBytes(64).toString('hex') |> console.log"
JWT_SECRET=replace-with-a-strong-random-secret-at-least-64-chars

# ──────────────────────────────────────────────────────────────
# Redis
# ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────────────────────────
# Email — Brevo (https://app.brevo.com/settings/keys/api)
# ──────────────────────────────────────────────────────────────
BREVO_API_KEY=
BREVO_SENDER_NAME=Yulaa
BREVO_SENDER_EMAIL=noreply@yulaa.in

# ──────────────────────────────────────────────────────────────
# SMS / OTP — Twilio (https://console.twilio.com)
# Leave blank in development to use the console-log fallback
# ──────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ──────────────────────────────────────────────────────────────
# App metadata (exposed to browser via NEXT_PUBLIC_)
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Yulaa
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
# Cron route protection
# Generate: node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
# ──────────────────────────────────────────────────────────────
CRON_SECRET=

# ──────────────────────────────────────────────────────────────
# Local dev: extra origins allowed by Next.js dev server
# Comma-separated, e.g. 192.168.1.10,172.16.20.233
# ──────────────────────────────────────────────────────────────
ALLOWED_DEV_ORIGINS=
